---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const allDevices = await getCollection('devices');
const featuredDevices = allDevices.filter(device => device.data.featured);

const mlPerfilLink = "https://listado.mercadolibre.com.ar/_CustId_119316055?item_id=MLA1996684374&category_id=MLA432881&seller_id=119316055&client=recoview-selleritems&recos_listing=true#origin=vip&component=sellerData&typeSeller=classic";
const waLink = "https://wa.me/541165361612";
const igLink = "https://www.instagram.com/almamia3d/";
const discordLink = "https://discord.gg/antarestai";
const githubLink = "https://github.com/AntaresTai";

const faqs = [
    { 
        q: "¿Cómo puedo comprar y qué métodos de pago aceptan?", 
        a: "Podés comprar por Mercado Libre para mayor seguridad, o contactarme directo para aprovechar descuentos. Acepto efectivo, tarjetas, transferencias, Mercado Pago y criptomonedas." 
    },
    { 
        q: "¿Hacen envíos a todo el país?", 
        a: "Sí, despachamos a toda Argentina a través del correo de tu preferencia para que elijas el que más te convenga." 
    },
    { 
        q: "¿Son difíciles de configurar y dónde veo las instrucciones?", 
        a: "Son totalmente plug & play en Windows y Mac. Cada producto tiene su manual en el botón 'Setup & Config' para que puedas personalizar macros con VIA sin saber programar. Si te trabás, te brindo soporte directo por Discord." 
    },
    { 
        q: "¿Realizan pedidos o diseños personalizados?", 
        a: "¡Claro! Si necesitás un formato específico, colores y keycaps particulares o un diseño a medida, escribime y armamos el equipo ideal para vos." 
    }
];
---

<Layout title="Antares | Periféricos Custom">
    <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none bg-white dark:bg-gray-950 transition-colors duration-500">
        <div 
            class="absolute inset-0 opacity-[0.4] dark:opacity-[0.7]" 
            style="background: 
                linear-gradient(135deg, var(--pcb-line) 2px, transparent 2px),
                linear-gradient(225deg, var(--pcb-line) 2px, transparent 2px),
                radial-gradient(var(--pcb-pad) 4px, transparent 4px);
                background-size: 60px 60px, 60px 60px, 60px 60px;
                background-position: 0 0, 30px 0, 30px 30px;
                background-color: var(--pcb-bg);"
        ></div>
        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-white/50 dark:via-gray-950/50 to-white dark:to-gray-950"></div>
    </div>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 min-h-screen flex flex-col justify-center relative z-10 pt-20">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
            
            <div class="lg:col-span-8 animate-fade-in">
                <div class="flex items-center gap-4 mb-6">
                    <span class="h-px w-12 bg-purple-600"></span>
                    <span class="text-xs font-black uppercase tracking-[0.4em] text-purple-600">Engineering & Design</span>
                </div>
                
                <h1 id="interactive-title" class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl xl:text-9xl font-black tracking-tighter text-gray-900 dark:text-white leading-[0.9] uppercase break-keep">
                    Periféricos <br/> 
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-gray-400 via-purple-500 to-gray-400 dark:from-gray-600 dark:via-purple-400 dark:to-gray-600 animate-gradient-x italic">Custom.</span>
                </h1>
            </div>

            <div class="lg:col-span-4 border-l-2 border-purple-600/20 pl-8 py-4 animate-fade-in delay-200">
                <p class="text-sm font-black uppercase tracking-widest text-purple-600 mb-2">The Maker</p>
                <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">Antares Cabrera.</h2>
                <p class="text-gray-600 dark:text-gray-400 font-light leading-relaxed mb-6">
                    Estudiante de <span class="font-medium text-gray-900 dark:text-white">Ingeniería en Informática</span>, apasionado por el hardware y el código. <br/>
                    Cada pieza es <span class="italic font-medium text-gray-900 dark:text-white underline decoration-purple-500/30 underline-offset-4">desarrollada y ensamblada a mano</span> por mí para garantizar la máxima calidad.
                </p>
                <a href="#store" class="inline-flex items-center text-xs font-black uppercase tracking-widest text-gray-900 dark:text-white hover:text-purple-600 transition-colors group">
                    Explorar dispositivos 
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-2 transform group-hover:translate-y-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7" /></svg>
                </a>
            </div>
        </div>

        <div id="reveal-text" class="mt-32 max-w-4xl opacity-0 translate-y-10 transition-all duration-1000 ease-out border-y border-gray-200 dark:border-gray-800 py-12">
            <blockquote class="text-xl md:text-3xl font-light text-gray-500 dark:text-gray-400 leading-tight">
                "Todo lo que ves acá nace de la curiosidad y necesidad. No solo diseño estos periféricos, sino que <span class="text-gray-900 dark:text-white font-medium italic">son los mismos que uso en mi día a día</span> para trabajar, estudiar y jugar."
            </blockquote>
        </div>
    </section>

    <section id="store" class="py-24 bg-gray-50 dark:bg-gray-900/50 transition-colors duration-500 border-t border-gray-200 dark:border-gray-800 relative z-20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center mb-16 px-4">
                <h2 class="text-3xl font-black text-gray-900 dark:text-white mr-8 uppercase tracking-tighter">Productos / Proyectos</h2>
                <div class="h-px bg-gray-300 dark:bg-gray-800 flex-grow"></div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 px-4">
                {featuredDevices.map((device) => (
                    <div class="group relative bg-white/60 dark:bg-white/[0.03] backdrop-blur-md border border-white/40 dark:border-white/10 rounded-[2.5rem] overflow-hidden shadow-xl transition-all duration-700 hover:-translate-y-3 hover:shadow-2xl hover:border-purple-500/50 flex flex-col will-change-transform">
                        <div class="absolute inset-0 -translate-x-full group-hover:translate-x-full bg-gradient-to-r from-transparent via-white/20 to-transparent transition-transform duration-1000 ease-in-out pointer-events-none z-20"></div>

                        <div class="h-72 overflow-hidden relative z-10">
                            {device.data.image ? (
                                <Image src={device.data.image as any} alt={device.data.title} width={800} height={600} format="webp" class="w-full h-full object-cover transform transition-transform duration-700 group-hover:scale-105 will-change-transform" />
                            ) : (
                                <div class="w-full h-full flex items-center justify-center text-7xl bg-gray-200 dark:bg-gray-800">🛠️</div>
                            )}
                        </div>

                        <div class="p-10 flex flex-col flex-grow relative z-10">
                            <div class="flex flex-wrap gap-1.5 mb-4">
                                {device.data.tags && device.data.tags.map((tag: string) => (
                                    <span class="text-[9px] font-black uppercase tracking-widest text-purple-600 dark:text-purple-400 bg-purple-100/50 dark:bg-purple-900/30 px-2.5 py-1 rounded border border-purple-200/50 dark:border-purple-800/50">{tag}</span>
                                ))}
                            </div>
                            <h3 class="text-3xl font-black text-gray-900 dark:text-white mb-3 uppercase tracking-tighter leading-tight font-sans text-ellipsis overflow-hidden">{device.data.title}</h3>
                            <p class="text-gray-600 dark:text-gray-400 text-base mb-10 leading-relaxed font-light line-clamp-3">{device.data.description}</p>
                            <div class="mt-auto flex items-center gap-4">
                                <a href={`/devices/${device.id}`} class="flex-grow flex justify-center items-center bg-gray-900 dark:bg-white text-white dark:text-gray-900 py-4 rounded-2xl font-black uppercase text-xs tracking-[0.1em] transition-all hover:bg-purple-600 dark:hover:bg-purple-400 dark:hover:text-white shadow-lg">Setup & Config</a>
                                {device.data.mercadolibreUrl && (
                                    <a href={device.data.mercadolibreUrl} target="_blank" aria-label={`Comprar ${device.data.title}`} class="flex items-center justify-center w-14 h-14 bg-white/50 dark:bg-white/5 border border-gray-300 dark:border-white/10 rounded-2xl hover:border-yellow-500 hover:text-yellow-600 text-gray-500 transition-all shrink-0">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.56-7.43H5.05"/></svg>
                                    </a>
                                )}
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <section id="faq" class="py-24 bg-gray-100 dark:bg-gray-950 transition-colors duration-500 border-t border-gray-200 dark:border-gray-800 relative z-20">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center mb-16">
                <h2 class="text-3xl font-black text-gray-900 dark:text-white mr-8 uppercase tracking-tighter">Preguntas Frecuentes</h2>
                <div class="h-px bg-gray-300 dark:bg-gray-800 flex-grow"></div>
            </div>
            
            <div class="space-y-4">
                {faqs.map(faq => (
                    <details class="group relative bg-white/50 dark:bg-white/[0.02] backdrop-blur-md border border-white/40 dark:border-white/10 rounded-2xl overflow-hidden transition-all duration-300 hover:bg-white/80 dark:hover:bg-white/[0.04]">
                        <summary class="flex justify-between items-center p-6 cursor-pointer list-none font-bold text-gray-900 dark:text-gray-100 group-hover:text-purple-600 dark:group-hover:text-purple-400 transition-colors duration-300">
                            <span class="transform group-hover:translate-x-2 transition-transform duration-300">{faq.q}</span>
                            <span class="text-purple-600 transform transition-transform duration-500 group-open:rotate-180">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                            </span>
                        </summary>
                        <div class="overflow-hidden max-h-0 group-open:max-h-[300px] opacity-0 group-open:opacity-100 transition-all duration-500 ease-in-out">
                            <div class="p-6 pt-0 text-gray-600 dark:text-gray-400 font-light leading-relaxed transform -translate-y-2 group-open:translate-y-0 transition-transform duration-500">
                                {faq.a}
                            </div>
                        </div>
                    </details>
                ))}
            </div>
        </div>
    </section>

    <section id="contact" class="py-24 bg-gray-200 dark:bg-[#050505] border-t border-gray-300 dark:border-gray-800 relative z-20 transition-colors duration-500">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center mb-16 px-4">
                <h2 class="text-3xl font-black text-gray-900 dark:text-white mr-8 uppercase tracking-tighter">Contacto</h2>
                <div class="h-px bg-gray-400 dark:bg-gray-700 flex-grow"></div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 px-4">
                <div class="space-y-12">
                    <h3 class="text-5xl font-black text-gray-900 dark:text-white uppercase leading-none tracking-tighter">Llevá tu setup <br/> al próximo nivel.</h3>
                    <p class="text-xl text-gray-600 dark:text-gray-400 font-light leading-relaxed">
                        Si buscás un dispositivo custom para tu setup o necesitás soporte técnico con tu compra, escribime. Atiendo pedidos por mayor y consultas.
                    </p>
                    <div class="flex gap-4">
                        <a href={waLink} target="_blank" aria-label="WhatsApp" class="flex items-center justify-center w-14 h-14 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl hover:border-green-500 hover:text-green-500 text-gray-500 dark:text-gray-400 transition-all shadow-sm hover:-translate-y-1"><svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9" /><path d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1" /></svg></a>
                        <a href={igLink} target="_blank" aria-label="Instagram" class="flex items-center justify-center w-14 h-14 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl hover:border-pink-500 hover:text-pink-500 text-gray-500 dark:text-gray-400 transition-all shadow-sm hover:-translate-y-1"><svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4m0 4a4 4 0 0 1 4 -4h8a4 4 0 0 1 4 4v8a4 4 0 0 1 -4 4h-8a4 4 0 0 1 -4 -4z" /><path d="M12 12m-3 0a3 3 0 1 0 6 0a3 3 0 1 0 -6 0" /><path d="M16.5 7.5l0 .01" /></svg></a>
                        <a href={discordLink} target="_blank" aria-label="Discord" class="flex items-center justify-center w-14 h-14 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl hover:border-indigo-500 hover:text-indigo-500 text-gray-500 dark:text-gray-400 transition-all shadow-sm hover:-translate-y-1"><svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M8 12a1 1 0 1 0 2 0a1 1 0 0 0 -2 0" /><path d="M14 12a1 1 0 1 0 2 0a1 1 0 0 0 -2 0" /><path d="M15.5 17c0 1 1.5 3 2 3c1.5 0 2.833 -1.667 3.5 -3c.667 -1.667 .5 -5.833 -1.5 -11.5c-1.457 -1.015 -3 -1.5 -4.5 -1.5l-1 2.5l-2 0l-1 -2.5c-1.5 0 -3.043 .485 -4.5 1.5c-2 5.667 -2.167 9.833 -1.5 11.5c.667 1.333 2 3 3.5 3c.5 0 2 -2 2 -3" /></svg></a>
                    </div>
                </div>

                <div class="bg-gray-50 dark:bg-gray-900/50 p-8 md:p-12 rounded-[2.5rem] border border-gray-300 dark:border-gray-800">
                    <form action="https://formspree.io/f/xwvrbzob" method="POST" class="space-y-6">
                        <div>
                            <label for="name" class="block text-[10px] font-black uppercase tracking-widest text-gray-500 mb-2">Tu Nombre</label>
                            <input id="name" type="text" name="name" required class="w-full bg-white dark:bg-gray-800 border-none rounded-xl p-4 focus:ring-2 focus:ring-purple-500 text-gray-900 dark:text-white outline-none placeholder-gray-400" placeholder="Tu nombre..." />
                        </div>
                        <div>
                            <label for="email" class="block text-[10px] font-black uppercase tracking-widest text-gray-500 mb-2">Email</label>
                            <input id="email" type="email" name="email" required class="w-full bg-white dark:bg-gray-800 border-none rounded-xl p-4 focus:ring-2 focus:ring-purple-500 text-gray-900 dark:text-white outline-none placeholder-gray-400" placeholder="tu@email.com" />
                        </div>
                        <div>
                            <label for="message" class="block text-[10px] font-black uppercase tracking-widest text-gray-500 mb-2">Consulta</label>
                            <textarea id="message" name="message" rows="4" required class="w-full bg-white dark:bg-gray-800 border-none rounded-xl p-4 focus:ring-2 focus:ring-purple-500 text-gray-900 dark:text-white outline-none resize-none placeholder-gray-400" placeholder="¿En qué puedo ayudarte?"></textarea>
                        </div>
                        <button type="submit" class="w-full bg-purple-600 hover:bg-purple-500 text-white font-black uppercase py-5 rounded-2xl text-xs tracking-[0.2em] transition-all shadow-xl shadow-purple-500/20">Enviar Consulta</button>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <footer class="py-12 bg-gray-200 dark:bg-[#050505] border-t border-gray-300 dark:border-gray-800 text-center relative z-20">
        <p class="text-[10px] uppercase tracking-[0.3em] text-gray-500 font-bold mb-4 px-4">© 2026 Antares, Argentina.</p>
        <a href={mlPerfilLink} target="_blank" class="text-[9px] uppercase tracking-widest text-gray-400 dark:text-gray-600 hover:text-yellow-600 dark:hover:text-yellow-500 transition-colors opacity-60 hover:opacity-100">Tienda Oficial Mercado Libre</a>
    </footer>

    <script is:inline>
        const title = document.getElementById('interactive-title');
        if (title) {
            const text = title.innerText;
            title.innerHTML = '';
            [...text].forEach(char => {
                const span = document.createElement('span');
                span.innerText = char === ' ' ? '\u00A0' : char;
                if (char === '\n') title.appendChild(document.createElement('br'));
                else {
                    span.className = 'inline-block transition-transform duration-300 hover:text-purple-600 dark:hover:text-purple-400 hover:scale-110 cursor-default';
                    title.appendChild(span);
                }
            });
        }

        const revealText = document.getElementById('reveal-text');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 150 && revealText) {
                revealText.classList.remove('opacity-0', 'translate-y-10');
                revealText.classList.add('opacity-100', 'translate-y-0');
            }
        }, { passive: true });
    </script>
</Layout>

<style is:global>
    :root { --pcb-bg: #f9fafb; --pcb-line: rgba(0, 0, 0, 0.05); --pcb-pad: rgba(0, 0, 0, 0.1); }
    .dark { --pcb-bg: #070707; --pcb-line: rgba(255, 255, 255, 0.03); --pcb-pad: rgba(255, 255, 255, 0.07); }
    @keyframes gradient-x { 0%, 100% { background-size: 200% 200%; background-position: left center; } 50% { background-size: 200% 200%; background-position: right center; } }
    .animate-gradient-x { animation: gradient-x 10s ease infinite; }
    .will-change-transform { will-change: transform; }
    summary::-webkit-details-marker { display: none; }
</style>