                                </div>
                                <div class="space-y-1">
                                    <p class="text-xs text-gray-700 dark:text-gray-300 font-medium">Ciudad Evita, Buenos Aires</p>
                                    <p class="text-[10px] text-gray-400 dark:text-gray-500 tracking-wide">Despachamos a todo el país</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="space-y-6">
                        <h4 class="text-[10px] font-bold text-gray-900 dark:text-white uppercase tracking-widest">// tienda oficial</h4>
                        <div class="space-y-4">
                            <a href={mlPerfilLink} target="_blank" class="group flex items-center gap-4 text-xs text-gray-500 dark:text-gray-400 hover:text-yellow-500 transition-colors">
                                <div class="w-8 h-8 rounded-lg bg-gray-100 dark:bg-white/5 flex items-center justify-center shrink-0 group-hover:bg-yellow-500/10 transition-colors">
