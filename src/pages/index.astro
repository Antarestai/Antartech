                            </a>
                        </div>
                    </div>
                </div>

                <!-- Columna 2: Ubicación & Enlaces -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-10 md:col-span-2">
                    <div class="space-y-6">
                        <h4 class="text-[10px] font-bold text-gray-900 dark:text-white uppercase tracking-widest">// donde estamos</h4>
                        <div class="space-y-4">
                            <div class="flex items-start gap-4">
                                <div class="w-8 h-8 rounded-lg bg-gray-100 dark:bg-white/5 flex items-center justify-center shrink-0">
