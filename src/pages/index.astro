                    <a href="/" class="text-2xl font-black bg-clip-text text-transparent bg-gradient-to-r from-indigo-600 to-cyan-500 dark:from-indigo-400 dark:to-cyan-400" style="font-family: system-ui, sans-serif">AntarTech</a>
                    <p class="text-sm text-gray-500 dark:text-gray-400 font-light leading-relaxed">
                        Periféricos custom diseñados y ensamblados a mano. Cada dispositivo es único.
                    </p>
                    <!-- Solo Discord -->
                    <a href="https://discord.gg/32RFVHPGYU" target="_blank" class="inline-flex items-center gap-2 text-xs text-gray-400 dark:text-gray-500 hover:text-indigo-500 dark:hover:text-indigo-400 transition-colors font-medium">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M8 12a1 1 0 1 0 2 0a1 1 0 0 0 -2 0" /><path d="M14 12a1 1 0 1 0 2 0a1 1 0 0 0 -2 0" /><path d="M15.5 17c0 1 1.5 3 2 3c1.5 0 2.833 -1.667 3.5 -3c.667 -1.667 .5 -5.833 -1.5 -11.5c-1.457 -1.015 -3 -1.5 -4.5 -1.5l-1 2.5l-2 0l-1 -2.5c-1.5 0 -3.043 .485 -4.5 1.5c-2 5.667 -2.167 9.833 -1.5 11.5c.667 1.333 2 3 3.5 3c.5 0 2 -2 2 -3" /></svg>
                        discord.gg/antares
                    </a>
                </div>

                <!-- Columna 2: Links & Redes -->
                <div class="space-y-4">
                    <h4 class="text-xs font-bold text-gray-900 dark:text-white">// navegación</h4>
                    <ul class="space-y-2.5">
                        <li><a href="/#store" class="text-xs text-gray-500 dark:text-gray-400 hover:text-indigo-500 dark:hover:text-cyan-400 transition-colors">→ productos</a></li>
                        <li><a href="/#faq" class="text-xs text-gray-500 dark:text-gray-400 hover:text-indigo-500 dark:hover:text-cyan-400 transition-colors">→ faq</a></li>
                        <li><a href="/#contact" class="text-xs text-gray-500 dark:text-gray-400 hover:text-indigo-500 dark:hover:text-cyan-400 transition-colors">→ contacto</a></li>
                        <li><a href={mlPerfilLink} target="_blank" class="text-xs text-gray-500 dark:text-gray-400 hover:text-yellow-500 transition-colors flex items-center gap-1">
                            → mercadolibre
