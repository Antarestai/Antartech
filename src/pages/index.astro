---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import Gallery from '../components/Gallery.astro';
import Products from '../components/Products.astro';
import About from '../components/About.astro';
import FAQ from '../components/FAQ.astro';
import Contact from '../components/Contact.astro';
import UseCases from '../components/UseCases.astro';

const allDevices = await getCollection('devices');
let featuredDevices = allDevices.filter(device => device.data.featured);

// Sort devices by 'order' if it exists, otherwise put them at the end
featuredDevices.sort((a, b) => {
    const orderA = a.data.order ?? 999;
    const orderB = b.data.order ?? 999;
    return orderA - orderB;
});

const mlPerfilLink = "https://listado.mercadolibre.com.ar/_CustId_119316055?item_id=MLA1996684374&category_id=MLA432881&seller_id=119316055&client=recoview-selleritems&recos_listing=true#origin=vip&component=sellerData&typeSeller=classic";
const discordLink = "https://discord.gg/antarestai";

---

<Layout
    title="Antares Tech | Periféricos custom"
    description="Periféricos custom diseñados y ensamblados a mano en Buenos Aires. Productos únicos, soporte directo y envíos a toda Argentina."
>
    <Hero />
    <Marquee />
    <Products featuredDevices={featuredDevices} />
    <UseCases />
    <Contact />
    <About />
    <Gallery />
    <FAQ />

    <footer class="relative z-20 bg-[#d5d0c8] dark:bg-[#02000d] transition-colors duration-700 overflow-hidden font-['Fira_Code']">
        <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-indigo-500/30 to-transparent"></div>
        <div class="absolute bottom-0 left-0 w-[400px] h-[400px] rounded-full bg-indigo-500/5 dark:bg-indigo-600/5 blur-[120px] pointer-events-none"></div>

        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-10 lg:gap-16">

                <!-- Columna 1: Marca & Redes -->
                <div class="space-y-6">
                    <div class="space-y-4">
                        <a href="/" class="text-2xl font-black bg-clip-text text-transparent bg-gradient-to-r from-indigo-600 to-cyan-500 dark:from-indigo-400 dark:to-cyan-400" style="font-family: system-ui, sans-serif">AntarTech</a>
                        <p class="text-sm text-gray-500 dark:text-gray-400 font-light leading-relaxed max-w-xs">
                            Periféricos custom diseñados y ensamblados a mano en Buenos Aires por <strong class="font-medium text-gray-900 dark:text-white">AlmaMia3D</strong>.
                        </p>
                    </div>
                    
                    <div class="space-y-4">
                        <h4 class="text-[10px] font-bold text-gray-900 dark:text-white uppercase tracking-widest">// encontranos</h4>
                        <div class="space-y-2">
                            <a href="https://www.instagram.com/almamia3d/" target="_blank" class="flex items-center gap-3 text-gray-500 dark:text-gray-400 hover:text-indigo-500 transition-colors group">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                                <span class="text-xs">@almamia3d</span>
                            </a>
                            
                            <a href="https://www.instagram.com/almamiadce/" target="_blank" class="flex items-center gap-3 text-gray-500 dark:text-gray-400 hover:text-indigo-500 transition-colors group">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                                <span class="text-xs">@almamiadce</span>
                            </a>

                            <a href="https://discord.gg/32RFVHPGYU" target="_blank" class="flex items-center gap-3 text-gray-500 dark:text-gray-400 hover:text-indigo-500 transition-colors group">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 12a1 1 0 1 0 2 0a1 1 0 0 0 -2 0" /><path d="M14 12a1 1 0 1 0 2 0a1 1 0 0 0 -2 0" /><path d="M15.5 17c0 1 1.5 3 2 3c1.5 0 2.833 -1.667 3.5 -3c.667 -1.667 .5 -5.833 -1.5 -11.5c-1.457 -1.015 -3 -1.5 -4.5 -1.5l-1 2.5l-2 0l-1 -2.5c-1.5 0 -3.043 .485 -4.5 1.5c-2 5.667 -2.167 9.833 -1.5 11.5c.667 1.333 2 3 3.5 3c.5 0 2 -2 2 -3" /></svg>
