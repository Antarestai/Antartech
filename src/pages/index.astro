---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allDevices = await getCollection('devices');
const featuredDevices = allDevices.filter(device => device.data.featured);
---

<Layout title="Antares | Ingeniería & Hardware Maker">
    <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 min-h-[90vh] flex flex-col justify-center items-start pt-32 pb-20">
        <div class="animate-fade-in space-y-6 w-full">
            
            <div class="flex items-center gap-4 mb-2">
                <span class="h-px w-8 md:w-12 bg-purple-600"></span>
                <span class="text-[10px] md:text-xs font-black uppercase tracking-[0.3em] text-purple-600">Handmade with dedication</span>
            </div>

            <h1 id="interactive-title" class="text-5xl sm:text-6xl md:text-8xl lg:text-[9rem] font-black tracking-tighter text-gray-900 dark:text-white leading-[0.85] uppercase break-words overflow-wrap-anywhere">
                Antares <br class="hidden md:block" /> 
                <span class="text-gray-400 dark:text-gray-600">Cabrera.</span>
            </h1>
            
            <h2 class="text-xl md:text-3xl font-light text-gray-500 dark:text-gray-400 leading-tight max-w-2xl transition-colors">
                Estudiante de <span class="font-medium text-gray-900 dark:text-white">Ingeniería en Informática</span> y Maker. <br class="hidden sm:block"/> Desarrollado y ensamblado a mano por mí.
            </h2>
        </div>

        <div id="reveal-text" class="mt-12 p-6 md:p-8 border-l-2 border-gray-200 dark:border-gray-800 transition-all duration-1000 ease-out opacity-0 translate-y-10 max-w-3xl">
            <p class="text-base md:text-lg text-gray-600 dark:text-gray-400 leading-relaxed font-light">
                Todo lo que ves acá nace de la curiosidad y necesidad. No solo diseño estos periféricos, sino que <span class="text-purple-600 dark:text-purple-400 font-medium italic underline decoration-purple-500/30 underline-offset-4">son los mismos que uso en mi día a día</span> para trabajar, estudiar y jugar. 
                <br/><br/>
                Mi objetivo es que cada pieza sea una herramienta pro, súper personalizable y fácil de configurar. Si sos de Argentina y buscás hardware con alma, estás en el lugar correcto.
            </p>
            
            <div class="mt-8 flex flex-wrap gap-6 items-center">
                <a href="#store" class="text-sm font-black uppercase tracking-widest text-gray-900 dark:text-white border-b-2 border-purple-600 pb-1 hover:text-purple-600 transition-colors">
                    Explorar dispositivos ↓
                </a>
                <div class="flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
                    <span class="text-xs text-gray-400 font-mono">Discord: antarestai</span>
                </div>
            </div>
        </div>
    </section>

    <section id="store" class="py-24 bg-gray-200 dark:bg-gray-900 transition-colors duration-500 border-t border-gray-300 dark:border-gray-800">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
            
            <div class="flex items-center mb-20">
                <h2 class="text-3xl font-black text-gray-900 dark:text-white mr-8 uppercase tracking-tighter">Proyectos / Productos</h2>
                <div class="h-px bg-gray-400 dark:bg-gray-700 flex-grow"></div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                {featuredDevices.map((device) => (
                    <div class="group bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-3xl overflow-hidden shadow-2xl transition-all duration-500 hover:-translate-y-4 hover:border-purple-500 flex flex-col">
                        
                        <div class="h-80 bg-gray-300 dark:bg-gray-700 overflow-hidden relative">
                            {device.data.image ? (
                                <img src={device.data.image} alt={device.data.title} class="w-full h-full object-cover transform transition-transform duration-700 group-hover:scale-105" />
                            ) : (
                                <div class="w-full h-full flex items-center justify-center text-7xl">🛠️</div>
                            )}
                            <div class="absolute bottom-6 left-6 flex gap-2">
                                {device.data.tags.map((tag: string) => (
                                    <span class="bg-gray-950/80 backdrop-blur-sm text-white px-3 py-1 rounded-md text-[9px] font-black uppercase tracking-widest border border-white/10">{tag}</span>
                                ))}
                            </div>
                        </div>

                        <div class="p-10">
                            <h3 class="text-4xl font-black text-gray-900 dark:text-white mb-4 uppercase tracking-tighter">{device.data.title}</h3>
                            <p class="text-gray-600 dark:text-gray-400 text-lg mb-8 leading-relaxed font-light">{device.data.description}</p>
                            
                            <div class="flex flex-col sm:flex-row gap-4">
                                <a href={`/devices/${device.id}`} class="flex-grow flex justify-center items-center bg-gray-900 dark:bg-white text-white dark:text-gray-900 py-5 rounded-2xl font-black uppercase text-xs tracking-[0.2em] transition-all hover:bg-purple-600 dark:hover:bg-purple-400 dark:hover:text-white">
                                    Documentación & Setup
                                </a>
                                <div class="flex items-center justify-center px-6 py-5 rounded-2xl border-2 border-gray-200 dark:border-gray-700 text-[10px] font-black uppercase tracking-widest text-gray-400">
                                    Argentina 🇦🇷
                                </div>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <footer class="py-16 text-center border-t border-gray-300 dark:border-gray-800 bg-gray-100 dark:bg-gray-950">
        <p class="text-[10px] uppercase tracking-[0.5em] text-gray-400 mb-4">"Ensamblado" con dedicación por Antares</p>
        <div class="flex justify-center gap-6 text-xs font-bold text-gray-500">
            <a href="https://discord.gg/antarestai" class="hover:text-purple-600 transition-colors">DISCORD</a>
            <a href="https://github.com/AntaresTai" class="hover:text-purple-600 transition-colors">GITHUB</a>
        </div>
    </footer>

    <script is:inline>
        // 1. Efecto letra por letra independiente
        const title = document.getElementById('interactive-title');
        if (title) {
            const text = title.innerText;
            title.innerHTML = '';
            [...text].forEach(char => {
                const span = document.createElement('span');
                span.innerText = char === ' ' ? '\u00A0' : char;
                // Si el carácter es un salto de línea (br), no le ponemos span
                if (char === '\n') {
                    const br = document.createElement('br');
                    title.appendChild(br);
                } else {
                    span.className = 'inline-block transition-all duration-300 hover:text-purple-600 dark:hover:text-purple-400 hover:-translate-x-2 cursor-default';
                    title.appendChild(span);
                }
            });
        }

        // 2. Lógica de Scroll Reveal obligatoria
        const revealText = document.getElementById('reveal-text');
        const handleScroll = () => {
            if (window.scrollY > 60 && revealText) {
                revealText.classList.remove('opacity-0', 'translate-y-10');
                revealText.classList.add('opacity-100', 'translate-y-0');
                window.removeEventListener('scroll', handleScroll);
            }
        };
        window.addEventListener('scroll', handleScroll);
    </script>
</Layout>