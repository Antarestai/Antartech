                            </div>

                            <a href={waCustomLink} target="_blank" class="block w-full text-center bg-gradient-to-r from-fuchsia-600 to-indigo-500 hover:from-fuchsia-500 hover:to-indigo-400 text-white font-black uppercase py-5 rounded-2xl text-xs tracking-[0.2em] transition-all duration-500 shadow-xl shadow-fuchsia-500/20 hover:shadow-fuchsia-500/30 hover:-translate-y-1">
