---
// src/components/Gallery.astro
const images = [
    { src: "/images/antaknob_setup.jpg", alt: "AntaKnob Setup", category: "AntaKnob", title: "Setup Minimalista", span: "md:col-span-2 md:row-span-2" },
    { src: "/images/macropad-ludmi1.jpg", alt: "Macropad Custom", category: "Macropad 12+1", title: "Custom Case", span: "" },
    { src: "/images/antaknob_setup3.jpg", alt: "AntaKnob Desk Setup", category: "Setup", title: "Estética Nocturna", span: "md:row-span-2" },
    { src: "/images/antaknob-setup4.jpg", alt: "Dark Setup", category: "Multimedia", title: "Dark Mode", span: "" },
    { src: "/images/power-button-color1.jpg", alt: "Power Button", category: "PC Switch", title: "Industrial Style", span: "" },
    { src: "/images/antaknob-setup5.jpg", alt: "Detalles", category: "Detalles", title: "Control Dinámico", span: "md:col-span-2" },
    { src: "/images/macropad.jpg", alt: "Macropad Productivity", category: "Productividad", title: "Atajos Infinitos", span: "" },
];
---

<section id="gallery" class="bg-[#d5d0c8]/30 dark:bg-[#030014]/60 transition-colors duration-700 relative z-20 overflow-hidden">
    <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-cyan-500/30 to-transparent"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 sm:pt-24 pb-8 sm:pb-12 text-center md:text-left">
        <div class="reveal-fade max-w-2xl">
            <div class="flex items-center gap-3 mb-4 justify-center md:justify-start">
                <span class="h-px w-8 bg-cyan-500"></span>
                <span class="text-[10px] font-black uppercase tracking-[0.3em] text-cyan-500">Comunidad AntarTech</span>
            </div>
            <h2 class="text-3xl sm:text-4xl md:text-6xl font-black text-gray-900 dark:text-white uppercase tracking-tighter mb-4">Setups / Galería</h2>
            <p class="text-gray-600 dark:text-gray-400 font-light text-base md:text-lg leading-relaxed">
                Inspiración de la comunidad. Dispositivos diseñados para verse impecables en tu escritorio. <br class="hidden md:block" />
                <span class="italic opacity-80 mt-2 block">¿Cómo se vería el tuyo con uno de estos?</span>
            </p>
        </div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-32">
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 auto-rows-[200px] sm:auto-rows-[250px] gap-3 sm:gap-4 md:gap-5">
            {images.map((img, idx) => (
                <figure class={`gallery-item relative group rounded-2xl sm:rounded-3xl overflow-hidden border border-white/40 dark:border-white/[0.05] shadow-sm hover:shadow-2xl hover:shadow-indigo-500/10 transition-all duration-500 ${img.span} reveal-item`} style={`--idx: ${idx}`}>
                    <div class="absolute inset-0 bg-gray-200 dark:bg-gray-800 animate-pulse -z-10 image-placeholder"></div>
                    <img 
                        src={img.src} 
                        alt={img.alt} 
                        class="w-full h-full object-cover transition-transform duration-1000 ease-out group-hover:scale-110 will-change-transform" 
                        loading="lazy" 
                        onload="this.previousElementSibling.style.display='none'"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent opacity-0 sm:group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-4 sm:p-6 pointer-events-none sm:pointer-events-auto">
                        <span class="text-[9px] sm:text-[10px] font-black uppercase tracking-[0.2em] text-cyan-400 mb-1">{img.category}</span>
                        <h3 class="text-white font-bold text-sm sm:text-base leading-tight">{img.title}</h3>
                        <div class="absolute top-3 right-3 sm:hidden px-2 py-1 bg-black/40 backdrop-blur-md rounded-md border border-white/10 opacity-70">
                             <span class="text-[8px] font-bold text-white uppercase tracking-tighter">{img.category}</span>
                        </div>
                    </div>
                    <div class="absolute inset-0 border-2 border-cyan-500/0 group-hover:border-cyan-500/20 transition-colors duration-500 rounded-2xl sm:rounded-3xl pointer-events-none"></div>
                </figure>
            ))}
        </div>
    </div>
</section>

<style>
    .gallery-item {
        transform: translateZ(0); /* Hardware acceleration */
        backface-visibility: hidden;
    }

    /* Scroll Reveal System */
    .reveal-item {
        opacity: 0;
        transform: translateY(30px);
        transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        transition-delay: calc(var(--idx) * 0.05s);
    }

    .reveal-item.visible {
        opacity: 1;
        transform: translateY(0);
    }

    .reveal-fade {
        opacity: 0;
        transform: translateY(20px);
        transition: all 1s ease-out;
    }

    .reveal-fade.visible {
        opacity: 1;
        transform: translateY(0);
    }

    /* Performance optimization for mobile gradients */
    @media (max-width: 768px) {
        .gallery-item img {
            transition-duration: 0.5s; /* Faster for mobile responsiveness */
        }
        /* Disable heavy hover effects on mobile to prevent flickering */
        .gallery-item:active img {
            transform: scale(1.05);
        }
    }
</style>

<script>
    // Intersection Observer for scroll reveal
    const observerOptions = {
        root: null,
        rootMargin: '0px',
        threshold: 0.1
    };

    const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible');
                // Once visible, stop observing
                revealObserver.unobserve(entry.target);
            }
        });
    }, observerOptions);

    // Initial items
    document.querySelectorAll('.reveal-item, .reveal-fade').forEach(el => {
        revealObserver.observe(el);
    });

    // Handle dynamic loading if images are added
    document.addEventListener('astro:page-load', () => {
        document.querySelectorAll('.reveal-item, .reveal-fade').forEach(el => {
            revealObserver.observe(el);
        });
    });
</script>
