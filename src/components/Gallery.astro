---
---

<section id="gallery" class="bg-[#d5d0c8]/30 dark:bg-[#030014]/60 transition-colors duration-700 relative z-20">
    <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-cyan-500/30 to-transparent"></div>

    <!-- Section Header -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 sm:pt-24 pb-8 sm:pb-12">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
            <div>
                <h2 class="text-2xl sm:text-3xl md:text-5xl font-black text-gray-900 dark:text-white uppercase tracking-tighter mb-2">Setups / Galería</h2>
                <p class="text-gray-600 dark:text-gray-400 font-light max-w-xl text-sm sm:text-base md:text-lg">
                    Inspiración de la comunidad. Dispositivos diseñados para verse impecables en tu escritorio.
                </p>
            </div>
            <div class="h-px bg-gradient-to-r from-cyan-500/50 to-transparent flex-grow md:max-w-md hidden md:block"></div>
        </div>
    </div>

    <!-- MOBILE: Compact 2-column grid (no sticky) -->
    <div class="lg:hidden max-w-7xl mx-auto px-4 sm:px-6 pb-16">
        <div class="grid grid-cols-2 gap-2 sm:gap-3">
            <figure class="w-full group">
                <div class="relative rounded-xl overflow-hidden border border-white/60 dark:border-white/[0.08] shadow-lg">
                    <img src="/images/antaknob_setup.jpg" alt="AntaKnob Setup" class="w-full h-36 sm:h-44 object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-3">
                        <span class="text-[10px] font-black uppercase tracking-widest text-cyan-400">AntaKnob</span>
                    </div>
                </div>
            </figure>
            <figure class="w-full group">
                <div class="relative rounded-xl overflow-hidden border border-white/60 dark:border-white/[0.08] shadow-lg">
                    <img src="/images/macropad-ludmi1.jpg" alt="Macropad Custom" class="w-full h-36 sm:h-44 object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-3">
                        <span class="text-[10px] font-black uppercase tracking-widest text-fuchsia-400">Macropad</span>
                    </div>
                </div>
            </figure>
            <figure class="w-full group">
                <div class="relative rounded-xl overflow-hidden border border-white/60 dark:border-white/[0.08] shadow-lg">
                    <img src="/images/antaknob_setup3.jpg" alt="AntaKnob Desk" class="w-full h-36 sm:h-44 object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-3">
                        <span class="text-[10px] font-black uppercase tracking-widest text-cyan-400">Setup</span>
                    </div>
                </div>
            </figure>
            <figure class="w-full group">
                <div class="relative rounded-xl overflow-hidden border border-white/60 dark:border-white/[0.08] shadow-lg">
                    <img src="/images/antaknob-setup4.jpg" alt="Dark Setup" class="w-full h-36 sm:h-44 object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-3">
                        <span class="text-[10px] font-black uppercase tracking-widest text-indigo-400">Dark Mode</span>
                    </div>
                </div>
            </figure>
            <figure class="w-full group">
                <div class="relative rounded-xl overflow-hidden border border-white/60 dark:border-white/[0.08] shadow-lg">
                    <img src="/images/power-button-color1.jpg" alt="Power Button" class="w-full h-36 sm:h-44 object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-3">
                        <span class="text-[10px] font-black uppercase tracking-widest text-emerald-400">PC Switch</span>
                    </div>
                </div>
            </figure>
            <figure class="w-full group">
                <div class="relative rounded-xl overflow-hidden border border-white/60 dark:border-white/[0.08] shadow-lg">
                    <img src="/images/antaknob-setup5.jpg" alt="AntaKnob" class="w-full h-36 sm:h-44 object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-3">
                        <span class="text-[10px] font-black uppercase tracking-widest text-yellow-400">Detalles</span>
                    </div>
                </div>
            </figure>
        </div>
    </div>

    <!-- DESKTOP: 3-column sticky layout -->
    <div class="hidden lg:block max-w-7xl mx-auto px-8 pb-24">
        <div class="grid grid-cols-3 gap-4">

            <!-- Left Column (scrolls) -->
            <div class="flex flex-col gap-4">
                <figure class="w-full group">
                    <div class="relative rounded-2xl overflow-hidden border border-white/60 dark:border-white/[0.08] shadow-xl shadow-indigo-500/5 dark:shadow-indigo-950/30">
                        <img src="/images/antaknob_setup.jpg" alt="AntaKnob Setup" class="w-full h-64 object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-5">
                            <span class="text-xs font-black uppercase tracking-widest text-cyan-400 mb-1">AntaKnob</span>
                            <h3 class="text-white font-medium text-sm">Setup Minimalista</h3>
                        </div>
                    </div>
                </figure>
                <figure class="w-full group">
                    <div class="relative rounded-2xl overflow-hidden border border-white/60 dark:border-white/[0.08] shadow-xl shadow-indigo-500/5 dark:shadow-indigo-950/30">
                        <img src="/images/macropad-ludmi1.jpg" alt="Macropad Custom" class="w-full h-64 object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-5">
                            <span class="text-xs font-black uppercase tracking-widest text-fuchsia-400 mb-1">Macropad 12+1</span>
                            <h3 class="text-white font-medium text-sm">Macropad Personalizado</h3>
                        </div>
                    </div>
                </figure>
                <figure class="w-full group">
                    <div class="relative rounded-2xl overflow-hidden border border-white/60 dark:border-white/[0.08] shadow-xl shadow-indigo-500/5 dark:shadow-indigo-950/30">
                        <img src="/images/antaknob-setup4.jpg" alt="AntaKnob Dark" class="w-full h-64 object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-5">
                            <span class="text-xs font-black uppercase tracking-widest text-indigo-400 mb-1">Multimedia</span>
                            <h3 class="text-white font-medium text-sm">Dark Mode Setup</h3>
                        </div>
                    </div>
                </figure>
            </div>

            <!-- Center Column (sticky) -->
            <div class="sticky top-0 h-screen flex flex-col gap-4 py-2">
                <figure class="w-full flex-1 group">
                    <div class="relative rounded-2xl overflow-hidden border border-white/60 dark:border-white/[0.08] shadow-xl shadow-indigo-500/5 dark:shadow-indigo-950/30 h-full">
                        <img src="/images/antaknob_setup3.jpg" alt="AntaKnob Desk Setup" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-5">
                            <span class="text-xs font-black uppercase tracking-widest text-cyan-400 mb-1">AntaKnob</span>
                            <h3 class="text-white font-medium text-sm">Estética Nocturna</h3>
                        </div>
                    </div>
                </figure>
                <figure class="w-full flex-1 group">
                    <div class="relative rounded-2xl overflow-hidden border border-white/60 dark:border-white/[0.08] shadow-xl shadow-indigo-500/5 dark:shadow-indigo-950/30 h-full">
                        <img src="/images/power-button-color1.jpg" alt="Power Button Colors" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-5">
                            <span class="text-xs font-black uppercase tracking-widest text-emerald-400 mb-1">PC Switch</span>
                            <h3 class="text-white font-medium text-sm">Estilo Industrial</h3>
                        </div>
                    </div>
                </figure>
                <figure class="w-full flex-1 group">
                    <div class="relative rounded-2xl overflow-hidden border border-white/60 dark:border-white/[0.08] shadow-xl shadow-indigo-500/5 dark:shadow-indigo-950/30 h-full">
                        <img src="/images/macropad.jpg" alt="Macropad" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-5">
                            <span class="text-xs font-black uppercase tracking-widest text-fuchsia-400 mb-1">Productividad</span>
                            <h3 class="text-white font-medium text-sm">Atajos infinitos</h3>
                        </div>
                    </div>
                </figure>
            </div>

            <!-- Right Column (scrolls) -->
            <div class="flex flex-col gap-4">
                <figure class="w-full group">
                    <div class="relative rounded-2xl overflow-hidden border border-white/60 dark:border-white/[0.08] shadow-xl shadow-indigo-500/5 dark:shadow-indigo-950/30">
                        <img src="/images/antaknob-setup5.jpg" alt="AntaKnob Macro" class="w-full h-64 object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-5">
                            <span class="text-xs font-black uppercase tracking-widest text-yellow-400 mb-1">Detalles</span>
                            <h3 class="text-white font-medium text-sm">Control Dinámico</h3>
                        </div>
                    </div>
                </figure>
                <figure class="w-full group">
                    <div class="relative rounded-2xl overflow-hidden border border-white/60 dark:border-white/[0.08] shadow-xl shadow-indigo-500/5 dark:shadow-indigo-950/30">
                        <img src="/images/macropad-ludmi1.jpg" alt="Macropad Ludmi" class="w-full h-64 object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-5">
                            <span class="text-xs font-black uppercase tracking-widest text-fuchsia-400 mb-1">Custom</span>
                            <h3 class="text-white font-medium text-sm">Hecho a mano</h3>
                        </div>
                    </div>
                </figure>
                <figure class="w-full group">
                    <div class="relative rounded-2xl overflow-hidden border border-white/60 dark:border-white/[0.08] shadow-xl shadow-indigo-500/5 dark:shadow-indigo-950/30">
                        <img src="/images/antaknob_setup.jpg" alt="AntaKnob Classic" class="w-full h-64 object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-5">
                            <span class="text-xs font-black uppercase tracking-widest text-cyan-400 mb-1">Workspace</span>
                            <h3 class="text-white font-medium text-sm">Clean Setup</h3>
                        </div>
                    </div>
                </figure>
            </div>

        </div>
    </div>
</section>
