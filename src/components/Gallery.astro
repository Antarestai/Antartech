---
---

<section id="gallery" class="py-32 bg-[#d5d0c8]/30 dark:bg-[#030014]/60 transition-colors duration-700 relative z-20 overflow-hidden">
    <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-cyan-500/30 to-transparent"></div>
    <div class="absolute right-0 top-20 w-[600px] h-[600px] rounded-full bg-cyan-500/5 dark:bg-cyan-600/10 blur-[120px] pointer-events-none animate-float-slow"></div>

    <div class="max-w-[90rem] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 px-4 scroll-reveal gap-6">
            <div>
                <h2 class="text-3xl md:text-5xl font-black text-gray-900 dark:text-white uppercase tracking-tighter mb-4">Setups / Galería</h2>
                <p class="text-gray-600 dark:text-gray-400 font-light max-w-xl text-lg">
                    Inspiración de la comunidad. Dispositivos diseñados no solo para funcionar, sino para verse impecables en tu escritorio.
                </p>
            </div>
            <div class="h-px bg-gradient-to-r from-cyan-500/50 to-transparent flex-grow md:max-w-md hidden md:block"></div>
        </div>
        
        <!-- Masonry Grid for Gallery -->
        <div class="columns-1 sm:columns-2 lg:columns-3 xl:columns-4 gap-6 px-4 space-y-6">
            
            <!-- Item 1 -->
            <div class="break-inside-avoid scroll-reveal">
                <a href="/devices/antaknob" class="block group relative rounded-3xl overflow-hidden shadow-xl shadow-indigo-500/5 dark:shadow-indigo-950/30 border border-white/60 dark:border-white/[0.08]">
                    <img src="/images/antaknob_setup.jpg" alt="AntaKnob Setup" class="w-full object-cover aspect-[4/5] transform transition-transform duration-1000 group-hover:scale-105 will-change-transform" loading="lazy" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-6">
                        <span class="text-xs font-black uppercase tracking-widest text-cyan-400 mb-1">AntaKnob</span>
                        <h3 class="text-white font-medium">Setup Minimalista</h3>
                    </div>
                </a>
            </div>

            <!-- Item 2 -->
            <div class="break-inside-avoid scroll-reveal" style="transition-delay: 50ms">
                <a href="/devices/macropad-12-1" class="block group relative rounded-3xl overflow-hidden shadow-xl shadow-indigo-500/5 dark:shadow-indigo-950/30 border border-white/60 dark:border-white/[0.08]">
                    <img src="/images/macropad-color1.jpg" alt="Macropad en escritorio" class="w-full object-cover aspect-square transform transition-transform duration-1000 group-hover:scale-105 will-change-transform" loading="lazy" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-6">
                        <span class="text-xs font-black uppercase tracking-widest text-fuchsia-400 mb-1">Macropad 12+1</span>
                        <h3 class="text-white font-medium">Edición Limitada</h3>
                    </div>
                </a>
            </div>

            <!-- Item 3 -->
            <div class="break-inside-avoid scroll-reveal" style="transition-delay: 100ms">
                <a href="/devices/antaknob" class="block group relative rounded-3xl overflow-hidden shadow-xl shadow-indigo-500/5 dark:shadow-indigo-950/30 border border-white/60 dark:border-white/[0.08]">
                    <img src="/images/antaknob_setup2.jpg" alt="AntaKnob en PC" class="w-full object-cover aspect-video transform transition-transform duration-1000 group-hover:scale-105 will-change-transform" loading="lazy" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-6">
                        <span class="text-xs font-black uppercase tracking-widest text-indigo-400 mb-1">Multimedia</span>
                        <h3 class="text-white font-medium">Control al alcance</h3>
                    </div>
                </a>
            </div>

            <!-- Item 4 -->
            <div class="break-inside-avoid scroll-reveal" style="transition-delay: 150ms">
                <a href="/devices/pc-power-button" class="block group relative rounded-3xl overflow-hidden shadow-xl shadow-indigo-500/5 dark:shadow-indigo-950/30 border border-white/60 dark:border-white/[0.08]">
                    <img src="/images/power-button-color1.jpg" alt="Power Button Colors" class="w-full object-cover aspect-[3/4] transform transition-transform duration-1000 group-hover:scale-105 will-change-transform" loading="lazy" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-6">
                        <span class="text-xs font-black uppercase tracking-widest text-emerald-400 mb-1">PC Switch</span>
                        <h3 class="text-white font-medium">Estilo Industrial</h3>
                    </div>
                </a>
            </div>

            <!-- Item 5 -->
            <div class="break-inside-avoid scroll-reveal" style="transition-delay: 200ms">
                <a href="/devices/antaknob" class="block group relative rounded-3xl overflow-hidden shadow-xl shadow-indigo-500/5 dark:shadow-indigo-950/30 border border-white/60 dark:border-white/[0.08]">
                    <img src="/images/antaknob.jpg" alt="AntaKnob Detalle" class="w-full object-cover aspect-square transform transition-transform duration-1000 group-hover:scale-105 will-change-transform" loading="lazy" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-6">
                        <span class="text-xs font-black uppercase tracking-widest text-yellow-400 mb-1">Detalles</span>
                        <h3 class="text-white font-medium">Acabado Premium</h3>
                    </div>
                </a>
            </div>

            <!-- Item 6 -->
            <div class="break-inside-avoid scroll-reveal" style="transition-delay: 250ms">
                <a href="/devices/pc-power-button" class="block group relative rounded-3xl overflow-hidden shadow-xl shadow-indigo-500/5 dark:shadow-indigo-950/30 border border-white/60 dark:border-white/[0.08]">
                    <img src="/images/power-button.jpg" alt="Power Button" class="w-full object-cover aspect-[4/5] transform transition-transform duration-1000 group-hover:scale-105 will-change-transform" loading="lazy" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-6">
                        <span class="text-xs font-black uppercase tracking-widest text-cyan-400 mb-1">PC Switch</span>
                        <h3 class="text-white font-medium">Start Engine</h3>
                    </div>
                </a>
            </div>

            <!-- Item 7 -->
            <div class="break-inside-avoid scroll-reveal" style="transition-delay: 300ms">
                <a href="/devices/macropad-12-1" class="block group relative rounded-3xl overflow-hidden shadow-xl shadow-indigo-500/5 dark:shadow-indigo-950/30 border border-white/60 dark:border-white/[0.08]">
                    <img src="/images/macropad.jpg" alt="Macropad" class="w-full object-cover aspect-video transform transition-transform duration-1000 group-hover:scale-105 will-change-transform" loading="lazy" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-6">
                        <span class="text-xs font-black uppercase tracking-widest text-fuchsia-400 mb-1">Productividad</span>
                        <h3 class="text-white font-medium">Atajos infinitos</h3>
                    </div>
                </a>
            </div>

        </div>
    </div>
</section>
