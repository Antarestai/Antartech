---
// src/components/CartDrawer.astro
// Este componente vive de forma global en Layout o Navbar y reacciona al estado de cartStore.js
---

<div id="cart-overlay" class="fixed inset-0 bg-black/40 dark:bg-black/60 backdrop-blur-sm z-[100] opacity-0 pointer-events-none transition-opacity duration-500">
</div>

<aside id="cart-drawer" class="fixed top-0 right-0 h-full w-full max-w-md bg-white/80 dark:bg-[#05001a]/80 backdrop-blur-3xl border-l border-white/40 dark:border-white/10 shadow-2xl z-[101] translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.25,1,0.5,1)] flex flex-col">
    <div class="absolute top-0 right-0 w-64 h-64 bg-fuchsia-500/10 blur-[80px] rounded-full pointer-events-none -mt-32 -mr-32"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-cyan-500/10 blur-[80px] rounded-full pointer-events-none -mb-32 -mx-32"></div>
    <div class="flex items-center justify-between p-6 border-b border-gray-200/50 dark:border-white/10 relative z-10">
        <h2 class="text-xl font-black uppercase tracking-widest text-gray-900 dark:text-white flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-indigo-500 dark:text-cyan-400"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.56-7.43H5.05"/></svg>
            Tu Pedido
        </h2>
        <button id="close-cart-btn" class="p-2 text-gray-500 hover:text-red-500 transition-colors rounded-full hover:bg-gray-100 dark:hover:bg-white/5" aria-label="Cerrar Carrito">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
    </div>
    <div id="cart-items-container" class="flex-grow p-6 overflow-y-auto space-y-4 relative z-10 custom-scrollbar">
        <div id="empty-cart-message" class="flex flex-col items-center justify-center h-full text-center opacity-50">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mb-4"><path d="m2 2 20 20"/><path d="M15.4 15.4a2 2 0 0 1-1.4.6H8a2 2 0 0 1-2-2V7.5L2.5 4h-1"/><path d="M17 17a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H8"/><path d="M8 21a2 2 0 0 0 2-2"/><path d="M17 21a2 2 0 0 0 2-2"/></svg>
            <p class="font-bold text-lg">Tu carrito está vacío</p>
            <p class="text-xs mt-1">¿Qué estás esperando?</p>
        </div>
    </div>
    <div class="p-6 bg-gray-50/80 dark:bg-black/40 backdrop-blur-xl border-t border-gray-200/50 dark:border-white/10 relative z-10">
        <div class="flex justify-between items-end mb-6">
            <div>
                <p class="text-xs uppercase tracking-widest text-gray-500 font-bold mb-1">Total Estimado</p>
                <div class="text-3xl font-black text-gray-900 dark:text-white" id="cart-total-price">$0</div>
            </div>
            <button id="clear-cart-btn" class="text-[10px] font-bold uppercase tracking-widest text-gray-400 hover:text-red-500 underline underline-offset-4 transition-colors">Vaciar todo</button>
        </div>

        <button id="checkout-wsp-btn" class="w-full flex items-center justify-center gap-3 bg-[#25D366] text-white py-4 rounded-xl font-black uppercase text-sm tracking-widest hover:bg-[#1EBE55] hover:scale-[1.02] hover:shadow-lg hover:shadow-[#25D366]/30 transition-all duration-300 disabled:opacity-50 disabled:cursor-not-allowed">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" class="animate-pulse" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Pedir por WhatsApp
        </button>
        <p class="text-[9px] text-center text-gray-400 mt-4 uppercase tracking-widest">Al enviar el mensaje, coordinaremos el envío y pago personalmente.</p>
    </div>
</aside>

<style>
    /* Ocultar barra de scroll pero mantener funcionalidad */
    .custom-scrollbar::-webkit-scrollbar {
        width: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(156, 163, 175, 0.3);
        border-radius: 4px;
    }
    
    .cart-item-enter {
        animation: slideInRight 0.3s ease-out forwards;
    }
    
    @keyframes slideInRight {
        from { opacity: 0; transform: translateX(20px); }
        to { opacity: 1; transform: translateX(0); }
    }
</style>

<script>
    import { cartStore, CART_UPDATED_EVENT } from '../scripts/cartStore.js';

    const initCartDrawer = () => {
        const overlay = document.getElementById('cart-overlay');
        const drawer = document.getElementById('cart-drawer');
        const closeBtn = document.getElementById('close-cart-btn');
        const clearBtn = document.getElementById('clear-cart-btn');
        const checkoutBtn = document.getElementById('checkout-wsp-btn');
        const itemsContainer = document.getElementById('cart-items-container');
        const emptyMessage = document.getElementById('empty-cart-message');
        const totalPriceEl = document.getElementById('cart-total-price');

        // Función para renderizar los items
        const renderItems = () => {
            if (!itemsContainer || !emptyMessage || !totalPriceEl || !checkoutBtn) return;
            
            const items = cartStore.items;
            
            if (items.length === 0) {
                emptyMessage.style.display = 'flex';
                // Borrar todo menos el mensaje de vacío
                Array.from(itemsContainer.children).forEach(child => {
                    if (child.id !== 'empty-cart-message') child.remove();
                });
                totalPriceEl.innerText = '$0';
                checkoutBtn.setAttribute('disabled', 'true');
            } else {
                emptyMessage.style.display = 'none';
                checkoutBtn.removeAttribute('disabled');
                
                // Formateador de moneda
                const formatter = new Intl.NumberFormat('es-AR', {
                    style: 'currency',
                    currency: 'ARS',
                    maximumFractionDigits: 0
                });

                totalPriceEl.innerText = formatter.format(cartStore.getTotalPrice());

                // Re-render items (en React esto es un map, acá lo hacemos a lo bruto pero rápido)
                // Primero limpiamos
                Array.from(itemsContainer.children).forEach(child => {
                    if (child.id !== 'empty-cart-message') child.remove();
                });

                items.forEach((item, idx) => {
                    const itemEl = document.createElement('div');
                    itemEl.className = 'cart-item-enter flex gap-4 p-4 bg-white/50 dark:bg-white/5 rounded-2xl border border-gray-200/50 dark:border-white/10 group';
                    itemEl.style.animationDelay = `${idx * 0.05}s`;
                    
                    itemEl.innerHTML = `
                        <div class="w-20 h-20 rounded-xl overflow-hidden bg-gray-100 dark:bg-gray-800 shrink-0 border border-gray-200 dark:border-white/10">
                            <img src="${item.image}" alt="${item.title}" class="w-full h-full object-cover" />
                        </div>
                        <div class="flex flex-col flex-grow justify-between">
                            <div class="flex justify-between items-start gap-2">
                                <h3 class="font-bold text-sm leading-tight text-gray-900 dark:text-white">${item.title}</h3>
                                <button class="delete-item-btn text-gray-400 hover:text-red-500 transition-colors p-1" data-id="${item.id}" aria-label="Eliminar item">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                                </button>
                            </div>
                            <div class="flex items-center justify-between mt-2">
                                <div class="flex items-center bg-gray-200/50 dark:bg-white/10 rounded-lg p-1">
                                    <button class="qty-minus-btn w-6 h-6 flex items-center justify-center rounded-md hover:bg-white dark:hover:bg-white/20 transition-colors text-gray-600 dark:text-gray-300" data-id="${item.id}">-</button>
                                    <span class="text-xs font-bold w-6 text-center text-gray-900 dark:text-white">${item.quantity}</span>
                                    <button class="qty-plus-btn w-6 h-6 flex items-center justify-center rounded-md hover:bg-white dark:hover:bg-white/20 transition-colors text-gray-600 dark:text-gray-300" data-id="${item.id}">+</button>
                                </div>
                                <span class="font-black text-indigo-600 dark:text-cyan-400">${formatter.format(item.price * item.quantity)}</span>
                            </div>
                        </div>
                    `;
                    
                    itemsContainer.appendChild(itemEl);
                });

                // Attach events a los botones recién creados
                document.querySelectorAll('.qty-plus-btn').forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        const id = (e.currentTarget as HTMLElement).dataset.id;
                        const item = cartStore.items.find(i => i.id === id);
                        if (item) cartStore.updateQuantity(id, item.quantity + 1);
                    });
                });

                document.querySelectorAll('.qty-minus-btn').forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        const id = (e.currentTarget as HTMLElement).dataset.id;
                        const item = cartStore.items.find(i => i.id === id);
                        if (item) cartStore.updateQuantity(id, item.quantity - 1);
                    });
                });

                document.querySelectorAll('.delete-item-btn').forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        const id = (e.currentTarget as HTMLElement).dataset.id;
                        cartStore.removeItem(id);
                    });
                });
            }
        };

        // UI Toggles (Abrir/Cerrar)
        const closeCart = () => {
            if(drawer) drawer.classList.add('translate-x-full');
            if(overlay) {
                overlay.classList.remove('opacity-100');
                overlay.classList.add('pointer-events-none');
            }
        };

        const openCart = () => {
            if(drawer) drawer.classList.remove('translate-x-full');
            if(overlay) {
                overlay.classList.add('opacity-100');
                overlay.classList.remove('pointer-events-none');
            }
            renderItems();
        };

        // Window Events para controlar la apertura desde otros componentes
        window.addEventListener('antares_open_cart', openCart);
        
        // Listeners del Cart Store (cada vez que se actualiza el store local, repintamos)
        window.addEventListener(CART_UPDATED_EVENT, renderItems);

        // Events
        if (closeBtn) closeBtn.addEventListener('click', closeCart);
        if (overlay) overlay.addEventListener('click', closeCart);
        
        if (clearBtn) {
            clearBtn.addEventListener('click', () => {
                cartStore.clearCart();
                const originalText = clearBtn.innerText;
                clearBtn.innerText = '😢 Pedido vaciado';
                clearBtn.classList.add('text-red-500');
                setTimeout(() => {
                    clearBtn.innerText = originalText;
                    clearBtn.classList.remove('text-red-500');
                }, 1500);
            });
        }

        if (checkoutBtn) {
            checkoutBtn.addEventListener('click', () => {
                window.open(cartStore.generateWhatsAppLink(), '_blank');
            });
        }

        // Render inicial si había elementos cacheados
        // Retrasamos el render inicial un tick para asegurarnos de que el store cargó
        setTimeout(renderItems, 50);
    };

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initCartDrawer);
    } else {
        initCartDrawer();
    }
</script>
