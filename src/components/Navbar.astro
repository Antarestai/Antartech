---
---
<nav id="navbar" class="fixed top-0 w-full z-50 bg-gray-100/60 dark:bg-gray-950/60 backdrop-blur-md border-b border-gray-300/50 dark:border-gray-800/50 transition-all duration-500 ease-in-out">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
            
            <div class="flex-shrink-0">
                <a href="/" class="text-xl font-black bg-clip-text text-transparent bg-gradient-to-r from-purple-600 to-cyan-500 dark:from-purple-400 dark:to-cyan-400">
                    AntarTech
                </a>
            </div>

          <div class="hidden md:flex items-center gap-8">
                <a href="/#store" class="relative text-xs font-bold uppercase tracking-widest text-gray-600 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-cyan-400 transition-colors duration-300 group">
                    Productos
                    <span class="absolute -bottom-1 left-0 w-0 h-[2px] bg-gradient-to-r from-indigo-500 to-cyan-400 transition-all duration-300 group-hover:w-full"></span>
                </a>
                <a href="/#gallery" class="relative text-xs font-bold uppercase tracking-widest text-gray-600 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-cyan-400 transition-colors duration-300 group">
                    Galería
                    <span class="absolute -bottom-1 left-0 w-0 h-[2px] bg-gradient-to-r from-indigo-500 to-cyan-400 transition-all duration-300 group-hover:w-full"></span>
                </a>
                <a href="/#contact" class="relative text-xs font-bold uppercase tracking-widest text-gray-600 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-cyan-400 transition-colors duration-300 group">
                    Contacto
                    <span class="absolute -bottom-1 left-0 w-0 h-[2px] bg-gradient-to-r from-indigo-500 to-cyan-400 transition-all duration-300 group-hover:w-full"></span>
                </a>
            </div>
            <div class="flex items-center gap-2">
                
                <button id="lang-toggle" type="button" class="flex items-center text-gray-600 dark:text-gray-400 hover:bg-gray-200/50 dark:hover:bg-gray-800/50 focus:outline-none rounded-lg text-[10px] px-2 py-1.5 transition-colors font-black">
                    <span id="lang-text">EN</span>
                </button>

                <div class="w-px h-4 bg-gray-300 dark:bg-gray-700"></div>

                <button id="theme-toggle" type="button" class="text-gray-600 dark:text-gray-400 hover:bg-gray-200/50 dark:hover:bg-gray-800/50 focus:outline-none rounded-lg text-sm p-2 transition-colors">
                    <svg id="theme-toggle-dark-icon" class="hidden w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path></svg>
                    <svg id="theme-toggle-light-icon" class="hidden w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"></path></svg>
                </button>
            </div>
            
        </div>
    </div>
</nav>

<script is:inline>
    // --- LÓGICA TEMA ---
    const themeToggleDarkIcon = document.getElementById('theme-toggle-dark-icon');
    const themeToggleLightIcon = document.getElementById('theme-toggle-light-icon');
    const themeToggleBtn = document.getElementById('theme-toggle');

    if (localStorage.getItem('color-theme') === 'dark' || (!('color-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        themeToggleLightIcon?.classList.remove('hidden');
        document.documentElement.classList.add('dark');
    } else {
        themeToggleDarkIcon?.classList.remove('hidden');
        document.documentElement.classList.remove('dark');
    }

    themeToggleBtn?.addEventListener('click', function() {
        themeToggleDarkIcon.classList.toggle('hidden');
        themeToggleLightIcon.classList.toggle('hidden');
        if (localStorage.getItem('color-theme') === 'light') {
            document.documentElement.classList.add('dark');
            localStorage.setItem('color-theme', 'dark');
        } else {
            document.documentElement.classList.remove('dark');
            localStorage.setItem('color-theme', 'light');
        }
    });

    // --- LÓGICA IDIOMA ---
    const langToggleBtn = document.getElementById('lang-toggle');
    const langText = document.getElementById('lang-text');
    langToggleBtn?.addEventListener('click', () => {
        langText.innerText = langText.innerText === 'EN' ? 'ES' : 'EN';
    });

    // --- LÓGICA OCULTAR NAVBAR (Intersection Observer) ---
    const nav = document.getElementById('navbar');
    const storeSection = document.getElementById('store');

    if (nav && storeSection) {
        const observerOptions = {
            // "rootMargin" de -80px para que el trigger sea un poquito antes de llegar arriba
            rootMargin: "-80px 0px 0px 0px",
            threshold: 0
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                // Si la sección de productos está "tocando" el tope de la pantalla
                if (entry.isIntersecting || window.scrollY > storeSection.offsetTop - 100) {
                    nav.style.transform = 'translateY(-100%)';
                    nav.style.opacity = '0';
                    nav.style.pointerEvents = 'none'; // Para que no bloquee clics mientras es invisible
                } else {
                    nav.style.transform = 'translateY(0)';
                    nav.style.opacity = '1';
                    nav.style.pointerEvents = 'auto';
                }
            });
        }, observerOptions);

        observer.observe(storeSection);

        // Fallback para scroll manual rápido
        window.addEventListener('scroll', () => {
            if (window.scrollY < 100) {
                nav.style.transform = 'translateY(0)';
                nav.style.opacity = '1';
                nav.style.pointerEvents = 'auto';
            }
        }, { passive: true });
    }
</script>