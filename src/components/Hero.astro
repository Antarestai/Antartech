    <!-- T — izquierda medio -->
    <svg class="keycap absolute left-[12%] top-[45%] w-16 h-16 text-cyan-500/[0.08] dark:text-cyan-400/[0.12] opacity-0" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" data-float-speed="1.0" data-float-range="15" data-enter-from="left" style="--enter-delay: 0.7s;">
        <rect x="6" y="6" width="52" height="52" rx="10" ry="10"/>
        <rect x="12" y="10" width="40" height="40" rx="6" ry="6"/>
        <text x="32" y="38" text-anchor="middle" fill="currentColor" font-size="18" font-weight="bold" font-family="monospace">T</text>
    </svg>
    <!-- A — derecha medio -->
    <svg class="keycap absolute right-[15%] top-[55%] w-20 h-20 text-indigo-500/[0.08] dark:text-indigo-400/[0.12] opacity-0" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" data-float-speed="0.7" data-float-range="20" data-enter-from="right" style="--enter-delay: 0.9s;">
        <rect x="6" y="6" width="52" height="52" rx="10" ry="10"/>
        <rect x="12" y="10" width="40" height="40" rx="6" ry="6"/>
        <text x="32" y="38" text-anchor="middle" fill="currentColor" font-size="18" font-weight="bold" font-family="monospace">A</text>
    </svg>
    <!-- R — izquierda abajo -->
    <svg class="keycap absolute left-[8%] bottom-[15%] w-28 h-28 text-fuchsia-500/[0.08] dark:text-fuchsia-400/[0.12] opacity-0" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" data-float-speed="0.5" data-float-range="25" data-enter-from="bottom" style="--enter-delay: 1.1s;">
        <rect x="6" y="6" width="52" height="52" rx="10" ry="10"/>
        <rect x="12" y="10" width="40" height="40" rx="6" ry="6"/>
        <text x="32" y="38" text-anchor="middle" fill="currentColor" font-size="18" font-weight="bold" font-family="monospace">R</text>
    </svg>
    <!-- E — centro derecha abajo -->
    <svg class="keycap absolute right-[25%] bottom-[10%] w-16 h-16 text-cyan-500/[0.08] dark:text-cyan-400/[0.12] opacity-0" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" data-float-speed="0.9" data-float-range="16" data-enter-from="bottom" style="--enter-delay: 1.3s;">
        <rect x="6" y="6" width="52" height="52" rx="10" ry="10"/>
        <rect x="12" y="10" width="40" height="40" rx="6" ry="6"/>
        <text x="32" y="38" text-anchor="middle" fill="currentColor" font-size="18" font-weight="bold" font-family="monospace">E</text>
    </svg>
    <!-- S — derecha abajo -->
    <svg class="keycap absolute right-[5%] bottom-[25%] w-20 h-20 text-indigo-500/[0.08] dark:text-indigo-400/[0.12] opacity-0" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" data-float-speed="0.65" data-float-range="19" data-enter-from="right" style="--enter-delay: 1.5s;">
        <rect x="6" y="6" width="52" height="52" rx="10" ry="10"/>
        <rect x="12" y="10" width="40" height="40" rx="6" ry="6"/>
        <text x="32" y="42" font-family="monospace" font-size="18" font-weight="bold" text-anchor="middle" fill="currentColor">S</text>
    </svg>
</div>

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 min-h-screen flex flex-col justify-center relative z-10 pt-20">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        
        <div class="lg:col-span-8 scroll-reveal relative z-10 group">
            <div class="flex items-center gap-4 mb-6">
                <span class="h-px w-16 bg-gradient-to-r from-fuchsia-600 to-cyan-500 animate-width-pulse"></span>
                <span class="text-xs font-black uppercase tracking-[0.4em] bg-clip-text text-transparent bg-gradient-to-r from-fuchsia-600 to-cyan-500">Engineering & Design</span>
            </div>
            
            <h1 id="interactive-title" class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl xl:text-9xl font-black tracking-tighter text-gray-900 dark:text-white leading-[0.9] uppercase break-keep relative">
                <span class="absolute -inset-8 bg-gradient-to-r from-fuchsia-500/20 via-indigo-500/10 to-cyan-500/20 blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-1000 -z-10 pointer-events-none"></span>
                Periféricos <br/> 
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-fuchsia-500 via-indigo-500 to-cyan-500 dark:from-fuchsia-400 dark:via-indigo-400 dark:to-cyan-400 animate-gradient-x italic filter drop-shadow-[0_0_25px_rgba(168,85,247,0.4)]">Custom.</span>
            </h1>
        </div>

        <div class="lg:col-span-4 border-l-2 border-indigo-600/30 pl-8 py-4 scroll-reveal delay-200">
            <div class="flex items-center gap-2 mb-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-indigo-500 dark:text-cyan-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                <p class="text-[10px] font-black uppercase tracking-[0.3em] text-indigo-500 dark:text-cyan-400">Maker & Developer</p>
            </div>
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-1 flex items-center gap-3">Antares Cabrera. <span class="inline-flex items-center gap-1.5 text-[9px] font-bold uppercase tracking-widest text-green-600 dark:text-green-400 bg-green-50 dark:bg-green-500/10 px-2.5 py-1 rounded-full border border-green-200/50 dark:border-green-500/20"><span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>Activo</span></h2>
            <p class="text-gray-600 dark:text-gray-300 font-light leading-relaxed mb-6">
                Estudiante de Ingeniería en Informática, apasionado por el hardware y el código. <br/>
                Cada pieza es <span class="italic font-medium text-gray-900 dark:text-white relative"><span class="relative z-10">desarrollada y ensamblada a mano</span><span class="absolute bottom-0 left-0 w-full h-2 bg-fuchsia-500/30 -z-10 rounded-sm"></span></span> por mí para garantizar la máxima calidad.
            </p>
        </div>
    </div>

    <!-- Scroll down indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 opacity-30 animate-pulse">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-gray-400 dark:text-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
    </div>

    <div id="reveal-text" class="mt-32 max-w-4xl opacity-0 translate-y-10 transition-all duration-1000 ease-out border-y border-gray-200 dark:border-gray-800 py-12">
        <blockquote id="quote-dissolve" class="text-xl md:text-3xl font-light text-gray-500 dark:text-gray-400 leading-relaxed">
            "Todo lo que ves acá nace de la curiosidad y necesidad. No solo diseño estos periféricos, sino que <span class="text-gray-900 dark:text-white font-medium italic">son los mismos que uso en mi día a día</span> para trabajar, estudiar y jugar."
        </blockquote>
    </div>
</section>

<script>
    // --- 3D Parallax Title Effect ---
    const title = document.getElementById('interactive-title');
    if (title) {
        const text = title.innerText;
        title.innerHTML = '';
        // Add perspective container
        title.style.perspective = '1200px';
        title.style.perspectiveOrigin = '50% 50%';
        
        const letterSpans = [];
        let i = 0;
        [...text].forEach(char => {
            if (char === '\n') {
                title.appendChild(document.createElement('br'));
            } else {
                const span = document.createElement('span');
                span.innerText = char === ' ' ? '\u00A0' : char;
                span.className = 'inline-block cursor-default transition-colors duration-200 hover:text-cyan-500 dark:hover:text-fuchsia-400';
                span.style.willChange = 'transform, opacity';
                span.style.transformStyle = 'preserve-3d';
                span.dataset.index = i;
                title.appendChild(span);
                letterSpans.push(span);
                i++;
            }
        });

        const totalLetters = letterSpans.length;
        let ticking = false;
        window.addEventListener('scroll', () => {
            if (!ticking) {
                requestAnimationFrame(() => {
                    const scrollY = window.scrollY;
                    const triggerStart = 50;
                    const triggerEnd = 600;
                    const progress = Math.max(0, Math.min(1, (scrollY - triggerStart) / (triggerEnd - triggerStart)));
                    
                    // Smooth easing
                    const easeOut = 1 - Math.pow(1 - progress, 3);
                    
                    letterSpans.forEach((span, idx) => {
                        const wave = idx / totalLetters;
                        // Each letter starts its animation slightly later (cascade effect)
                        const letterProgress = Math.max(0, Math.min(1, (easeOut - wave * 0.2) / (1 - wave * 0.2)));
                        
                        if (letterProgress <= 0) {
                            span.style.transform = '';
                            span.style.opacity = '';
                            return;
                        }
                        
                        // 3D perspective: tilt backward into the screen
                        const rotateX = letterProgress * 45; // Tilt back
                        // Parallax: each letter moves at a different speed
                        const parallaxY = letterProgress * (-15 - wave * 40);
                        // Depth: letters recede into the screen (z-axis)
                        const translateZ = letterProgress * (-80 - wave * 120);
                        // Slight horizontal spread for drama
                        const spreadX = letterProgress * (idx - totalLetters / 2) * 1.5;
                        
                        const opacity = Math.max(0, 1 - letterProgress * 1.2);
                        
                        span.style.transform = `translate3d(${spreadX}px, ${parallaxY}px, ${translateZ}px) rotateX(${rotateX}deg)`;
                        span.style.opacity = opacity;
                    });
                    ticking = false;
                });
                ticking = true;
            }
        }, { passive: true });
    }

    // --- 3D Parallax Quote Effect ---
    const quoteEl = document.getElementById('quote-dissolve');
    if (quoteEl) {
        const rawText = quoteEl.innerText;
        const highlightPhrase = 'son los mismos que uso en mi día a día';
        
        // Add perspective to quote container
        quoteEl.style.perspective = '800px';
        quoteEl.style.perspectiveOrigin = '50% 100%';
        
        quoteEl.innerHTML = '';
        const words = rawText.split(/\s+/);
        const wordSpans = [];
        const highlightWords = highlightPhrase.split(/\s+/);
        let hlIdx = 0;
        let inHighlight = false;
        
        words.forEach((word, idx) => {
            if (!inHighlight && word === highlightWords[0]) {
                let match = true;
                for (let k = 0; k < highlightWords.length && idx + k < words.length; k++) {
                    if (words[idx + k] !== highlightWords[k]) { match = false; break; }
                }
                if (match) { inHighlight = true; hlIdx = 0; }
            }
            
            const span = document.createElement('span');
            span.innerText = word;
            span.className = 'inline-block';
            span.style.marginRight = '0.3em';
            span.style.willChange = 'transform, opacity';
            span.style.transformStyle = 'preserve-3d';
            
            if (inHighlight && hlIdx < highlightWords.length) {
                span.classList.add('font-medium', 'italic');
                span.dataset.highlight = 'true';
                hlIdx++;
                if (hlIdx >= highlightWords.length) inHighlight = false;
            }
            
            quoteEl.appendChild(span);
            wordSpans.push(span);
        });
        
        const totalWords = wordSpans.length;
        const centerIdx = totalWords / 2;
        let quoteTicking = false;
        
        window.addEventListener('scroll', () => {
            if (!quoteTicking) {
                requestAnimationFrame(() => {
                    const rect = quoteEl.getBoundingClientRect();
                    const vh = window.innerHeight;
                    
                    const triggerTop = vh * 0.4;
                    const endTop = -rect.height * 0.5;
                    
                    let progress;
                    if (rect.top > triggerTop) {
                        progress = 0;
                    } else if (rect.top < endTop) {
                        progress = 1;
                    } else {
                        progress = (triggerTop - rect.top) / (triggerTop - endTop);
                    }
                    
                    // Smooth cubic ease
                    const eased = progress * progress * (3 - 2 * progress);
                    
                    wordSpans.forEach((span, idx) => {
                        // Stagger: words at the edges dissolve faster than center
                        const distFromCenter = Math.abs(idx - centerIdx) / centerIdx;
                        const wordDelay = (1 - distFromCenter) * 0.3;
                        const wordProgress = Math.max(0, Math.min(1, (eased - wordDelay) / (1 - wordDelay)));
                        
                        if (wordProgress <= 0) {
                            span.style.transform = '';
                            span.style.opacity = '';
                            span.style.filter = '';
                            span.style.color = '';
                            return;
                        }
                        
                        const wp = wordProgress * wordProgress;
                        
                        // Parallax spread: words fly outward from center at different speeds
                        const direction = idx < centerIdx ? -1 : 1;
                        const spreadX = wp * direction * (20 + distFromCenter * 60);
                        // 3D: words tilt and recede
                        const rotateY = wp * direction * (8 + distFromCenter * 15);
                        const translateZ = wp * (-30 - distFromCenter * 80);
                        const moveY = wp * (-10 - distFromCenter * 15);
                        
                        const opacity = Math.max(0, 1 - wordProgress * 1.3);
                        const blur = wp * 3;
                        
                        span.style.transform = `translate3d(${spreadX}px, ${moveY}px, ${translateZ}px) rotateY(${rotateY}deg)`;
                        span.style.opacity = opacity;
                        span.style.filter = `blur(${blur}px)`;
                        
                        // Highlighted words pulse in brand color before fading
                        if (span.dataset.highlight && wordProgress > 0.05 && wordProgress < 0.5) {
                            const pulse = Math.sin(wordProgress / 0.5 * Math.PI);
                            const isDark = document.documentElement.classList.contains('dark');
                            span.style.color = isDark 
                                ? `rgba(165, 180, 252, ${0.7 + pulse * 0.3})` // indigo-300
                                : `rgba(79, 70, 229, ${0.7 + pulse * 0.3})`;  // indigo-600
                        } else {
                            span.style.color = '';
                        }
                    });
                    
                    quoteTicking = false;
                });
                quoteTicking = true;
            }
        }, { passive: true });
    }

    // --- Media Query Check ---
    const isMobile = window.matchMedia('(max-width: 768px)').matches;

    // --- Floating Particles Canvas ---
    const canvas = document.getElementById('particles-canvas');
    if (canvas) {
        const ctx = canvas.getContext('2d');
        let particles = [];
        const PARTICLE_COUNT = isMobile ? 15 : 40;
        const SHOW_CONNECTIONS = !isMobile;

        function resizeCanvas() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }
        resizeCanvas();
        window.addEventListener('resize', resizeCanvas, { passive: true });

        function createParticle() {
            const isDark = document.documentElement.classList.contains('dark');
            const colors = isDark
                ? ['rgba(168,85,247,', 'rgba(6,182,212,', 'rgba(99,102,241,']
                : ['rgba(99,102,241,', 'rgba(168,85,247,', 'rgba(6,182,212,'];
            const color = colors[Math.floor(Math.random() * colors.length)];
            return {
                x: Math.random() * canvas.width,
                y: Math.random() * canvas.height,
                radius: Math.random() * 2 + 0.5,
                speedX: (Math.random() - 0.5) * 0.3,
                speedY: (Math.random() - 0.5) * 0.3,
                opacity: Math.random() * 0.5 + 0.1,
                color: color
            };
        }

        for (let i = 0; i < PARTICLE_COUNT; i++) particles.push(createParticle());

        function drawParticles() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            particles.forEach(p => {
                p.x += p.speedX;
                p.y += p.speedY;
                if (p.x < 0) p.x = canvas.width;
                if (p.x > canvas.width) p.x = 0;
                if (p.y < 0) p.y = canvas.height;
                if (p.y > canvas.height) p.y = 0;
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
                ctx.fillStyle = p.color + p.opacity + ')';
                ctx.fill();
            });

            // Draw connections between nearby particles (Disabled on mobile for performance)
            if (SHOW_CONNECTIONS) {
                for (let i = 0; i < particles.length; i++) {
                    for (let j = i + 1; j < particles.length; j++) {
                        const dx = particles[i].x - particles[j].x;
                        const dy = particles[i].y - particles[j].y;
                        const dist = Math.sqrt(dx * dx + dy * dy);
                        if (dist < 150) {
                            ctx.beginPath();
                            ctx.moveTo(particles[i].x, particles[i].y);
                            ctx.lineTo(particles[j].x, particles[j].y);
                            const lineOpacity = (1 - dist / 150) * 0.15;
                            ctx.strokeStyle = particles[i].color + lineOpacity + ')';
                            ctx.lineWidth = 0.5;
                            ctx.stroke();
                        }
                    }
                }
            }
            requestAnimationFrame(drawParticles);
        }
        drawParticles();
    }

    // --- Mouse Parallax Effect --- (Disabled on mobile)
    if (!isMobile) {
        document.addEventListener('mousemove', (e) => {
            const x = (e.clientX / window.innerWidth - 0.5) * 2;
            const y = (e.clientY / window.innerHeight - 0.5) * 2;
    
            const layer1 = document.getElementById('parallax-layer-1');
            const layer2 = document.getElementById('parallax-layer-2');
            const layer3 = document.getElementById('parallax-layer-3');
    
            if (layer1) layer1.style.transform = `translate(${x * -60}px, ${y * -60}px)`; 
            if (layer2) layer2.style.transform = `translate(${x * -30}px, ${y * -30}px)`; 
            if (layer3) layer3.style.transform = `translate(${x * -90}px, ${y * -90}px)`; 
        });
    }

    // --- Keycap Entrance + Enhanced Floating ---
    const keycaps = document.querySelectorAll('.keycap');
    const keycapsContainer = document.getElementById('keycaps-container');
    
    // Check if container is visible (it's hidden on mobile via CSS hidden lg:block)
    const containerVisible = keycapsContainer && window.getComputedStyle(keycapsContainer).display !== 'none';

    if (keycaps.length > 0 && containerVisible) {
        // Clean entrance using CSS animations
        keycaps.forEach((kc, idx) => {
            const delay = kc.style.getPropertyValue('--enter-delay') || `${idx * 0.15 + 0.3}s`;
            kc.style.animationDelay = delay;
            
            // Trigger animation
            requestAnimationFrame(() => {
                kc.classList.add('animate-in');
            });
        });
        
        // Enhanced floating with JS (starts after entrance completes)
        setTimeout(() => {
            const startTime = performance.now();
            
            const keycapData = [];
            keycaps.forEach(kc => {
                // Remove animation class before starting JS floating to avoid conflicts
                kc.style.animation = 'none';
                kc.style.opacity = '1';

                keycapData.push({
                    el: kc,
                    speed: parseFloat(kc.dataset.floatSpeed) || 0.7,
                    range: parseFloat(kc.dataset.floatRange) || 18,
                    phaseX: Math.random() * Math.PI * 2,
                    phaseY: Math.random() * Math.PI * 2,
                    phaseR: Math.random() * Math.PI * 2,
                });
            });
            
            function animateKeycaps(now) {
                // Extra safety: stop if container becomes hidden (e.g. resize)
                if (window.getComputedStyle(keycapsContainer).display === 'none') return;

                const elapsed = (now - startTime) / 1000;
                // Ramp up intensity from 0 to 1 over 2 seconds for a seamless transition
                const ramp = Math.min(1, elapsed / 2.0);
                
                keycapData.forEach(data => {
                    const { el, speed, range, phaseX, phaseY, phaseR } = data;
                    const t = elapsed * speed;
                    
                    // Subtract initial value (Math.sin(phase)) to ensure we start at exactement 0,0
                    const x = (Math.sin(t * 0.7 + phaseX) - Math.sin(phaseX)) * range * 0.6 
                            + (Math.sin(t * 1.3 + phaseX * 2) - Math.sin(phaseX * 2)) * range * 0.3;
                    const y = (Math.sin(t * 0.5 + phaseY) - Math.sin(phaseY)) * range 
                            + (Math.cos(t * 0.9 + phaseY * 1.5) - Math.cos(phaseY * 1.5)) * range * 0.4;
                    const rotZ = (Math.sin(t * 0.4 + phaseR) - Math.sin(phaseR)) * 6 
                               + (Math.cos(t * 0.8 + phaseR * 2) - Math.cos(phaseR * 2)) * 3;
                    
                    el.style.transform = `translate3d(${x * ramp}px, ${y * ramp}px, 0) rotate(${rotZ * ramp}deg)`;
                });
                
                requestAnimationFrame(animateKeycaps);
            }
            
            requestAnimationFrame(animateKeycaps);
        }, 1200); // Shorter wait, start as they finish entering
    }
</script>

