    <svg class="keycap absolute left-[4%] top-[12%] w-20 h-20 text-indigo-500/[0.08] dark:text-indigo-400/[0.12] opacity-0" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" data-float-speed="0.8" data-float-range="18" data-enter-from="left" style="--enter-delay: 0.3s;">
        <rect x="6" y="6" width="52" height="52" rx="10" ry="10"/>
        <rect x="12" y="10" width="40" height="40" rx="6" ry="6"/>
        <text x="32" y="38" text-anchor="middle" fill="currentColor" font-size="18" font-weight="bold" font-family="monospace">A</text>
    </svg>
    <!-- N — derecha arriba -->
    <svg class="keycap absolute right-[8%] top-[18%] w-24 h-24 text-fuchsia-500/[0.08] dark:text-fuchsia-400/[0.12] opacity-0" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" data-float-speed="0.6" data-float-range="22" data-enter-from="top" style="--enter-delay: 0.5s;">
        <rect x="6" y="6" width="52" height="52" rx="10" ry="10"/>
        <rect x="12" y="10" width="40" height="40" rx="6" ry="6"/>
        <text x="32" y="38" text-anchor="middle" fill="currentColor" font-size="18" font-weight="bold" font-family="monospace">N</text>
