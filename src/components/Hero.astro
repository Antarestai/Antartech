---
// src/components/Hero.astro
---

<div id="hero-bg" class="fixed inset-0 -z-10 overflow-hidden pointer-events-none bg-[#d5d0c8] dark:bg-[#030014] transition-colors duration-700">
    <div id="parallax-layer-1" class="absolute inset-0 w-full h-full transition-transform duration-300 ease-out will-change-transform">
        <canvas id="particles-canvas" class="absolute inset-0 w-full h-full"></canvas>
    </div>
    
    <div id="parallax-layer-2"
        class="absolute inset-0 opacity-[0.3] dark:opacity-[0.8] transition-all duration-700 ease-out will-change-transform" 
        style="background: 
            linear-gradient(135deg, var(--pcb-line) 2px, transparent 2px),
            linear-gradient(225deg, var(--pcb-line) 2px, transparent 2px),
            radial-gradient(var(--pcb-pad) 4px, transparent 4px);
            background-size: 60px 60px, 60px 60px, 60px 60px;
            background-position: 0 0, 30px 0, 30px 30px;
            background-color: var(--pcb-bg);"
    ></div>
    
    <div class="absolute inset-0 bg-gradient-to-b from-[#d5d0c8]/40 via-[#d5d0c8]/80 to-[#d5d0c8] dark:from-transparent dark:via-[#030014]/60 dark:to-[#030014] transition-colors duration-700"></div>
    
    <div id="parallax-layer-3" class="absolute inset-0 w-full h-full transition-transform duration-500 ease-out will-change-transform">
        <div class="absolute top-0 right-[-10%] -mt-40 w-[500px] h-[500px] rounded-full bg-fuchsia-500/15 dark:bg-fuchsia-600/15 blur-[120px] pointer-events-none animate-float-slow"></div>
        <div class="absolute bottom-0 left-[-10%] -mb-40 w-[500px] h-[500px] rounded-full bg-cyan-500/15 dark:bg-cyan-600/15 blur-[120px] pointer-events-none animate-float-slow-reverse"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-indigo-500/5 dark:bg-indigo-600/10 blur-[150px] pointer-events-none animate-pulse-glow"></div>
    </div>
</div>

<style>
    /* Keycap Entrance Animations */
    @keyframes keycap-enter-left {
        from { opacity: 0; transform: translateX(-40px) scale(0.8) rotate(-10deg); }
        to { opacity: 1; transform: translateX(0) scale(1) rotate(0); }
    }
    @keyframes keycap-enter-right {
        from { opacity: 0; transform: translateX(40px) scale(0.8) rotate(10deg); }
        to { opacity: 1; transform: translateX(0) scale(1) rotate(0); }
    }
    @keyframes keycap-enter-top {
        from { opacity: 0; transform: translateY(-40px) scale(0.8) rotate(-5deg); }
        to { opacity: 1; transform: translateY(0) scale(1) rotate(0); }
    }
    @keyframes keycap-enter-bottom {
        from { opacity: 0; transform: translateY(40px) scale(0.8) rotate(5deg); }
        to { opacity: 1; transform: translateY(0) scale(1) rotate(0); }
    }

    .keycap {
        opacity: 0;
        will-change: transform, opacity;
    }

    .keycap.animate-in[data-enter-from="left"] { animation: keycap-enter-left 1s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
    .keycap.animate-in[data-enter-from="right"] { animation: keycap-enter-right 1s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
    .keycap.animate-in[data-enter-from="top"] { animation: keycap-enter-top 1s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
    .keycap.animate-in[data-enter-from="bottom"] { animation: keycap-enter-bottom 1s cubic-bezier(0.16, 1, 0.3, 1) forwards; }

    /* Performance optimization: hardware acceleration */
    #hero-bg, #keycaps-container {
        transform: translateZ(0);
        backface-visibility: hidden;
    }
</style>

<!-- Floating Keycaps decorativos — deletrean A·N·T·A·R·E·S -->
<div id="keycaps-container" class="fixed inset-0 pointer-events-none z-[2] overflow-hidden hidden lg:block">
