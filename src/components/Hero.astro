---
// src/components/Hero.astro
---

<div id="hero-bg" class="fixed inset-0 -z-10 overflow-hidden pointer-events-none bg-gray-50 dark:bg-[#030014] transition-colors duration-700">
    <div id="parallax-layer-1" class="absolute inset-0 w-full h-full transition-transform duration-300 ease-out will-change-transform">
        <canvas id="particles-canvas" class="absolute inset-0 w-full h-full"></canvas>
    </div>
    
    <div id="parallax-layer-2"
        class="absolute inset-0 opacity-[0.3] dark:opacity-[0.8] transition-all duration-700 ease-out will-change-transform" 
        style="background: 
            linear-gradient(135deg, var(--pcb-line) 2px, transparent 2px),
            linear-gradient(225deg, var(--pcb-line) 2px, transparent 2px),
            radial-gradient(var(--pcb-pad) 4px, transparent 4px);
            background-size: 60px 60px, 60px 60px, 60px 60px;
            background-position: 0 0, 30px 0, 30px 30px;
            background-color: var(--pcb-bg);"
    ></div>
    
    <div class="absolute inset-0 bg-gradient-to-b from-white/40 via-white/80 to-white dark:from-transparent dark:via-[#030014]/60 dark:to-[#030014] transition-colors duration-700"></div>
    
    <div id="parallax-layer-3" class="absolute inset-0 w-full h-full transition-transform duration-500 ease-out will-change-transform">
        <div class="absolute top-0 right-[-10%] -mt-40 w-[500px] h-[500px] rounded-full bg-fuchsia-500/15 dark:bg-fuchsia-600/15 blur-[120px] pointer-events-none animate-float-slow"></div>
        <div class="absolute bottom-0 left-[-10%] -mb-40 w-[500px] h-[500px] rounded-full bg-cyan-500/15 dark:bg-cyan-600/15 blur-[120px] pointer-events-none animate-float-slow-reverse"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-indigo-500/5 dark:bg-indigo-600/10 blur-[150px] pointer-events-none animate-pulse-glow"></div>
    </div>
</div>

<!-- Floating Keycaps decorativos — deletrean A·N·T·A·R·E·S -->
<div class="fixed inset-0 pointer-events-none z-[2] overflow-hidden hidden lg:block">
    <!-- A — izquierda arriba -->
    <svg class="absolute left-[4%] top-[12%] w-20 h-20 text-indigo-500/[0.08] dark:text-indigo-400/[0.12] animate-float-keycap" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="6" y="6" width="52" height="52" rx="10" ry="10"/>
        <rect x="12" y="10" width="40" height="40" rx="6" ry="6"/>
        <text x="32" y="38" text-anchor="middle" fill="currentColor" font-size="18" font-weight="bold" font-family="monospace">A</text>
    </svg>
    <!-- N — derecha arriba -->
    <svg class="absolute right-[8%] top-[18%] w-24 h-24 text-fuchsia-500/[0.08] dark:text-fuchsia-400/[0.12] animate-float-keycap-reverse" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" style="animation-delay: -2s;">
        <rect x="6" y="6" width="52" height="52" rx="10" ry="10"/>
        <rect x="12" y="10" width="40" height="40" rx="6" ry="6"/>
        <text x="32" y="38" text-anchor="middle" fill="currentColor" font-size="18" font-weight="bold" font-family="monospace">N</text>
    </svg>
    <!-- T — izquierda medio -->
    <svg class="absolute left-[12%] top-[45%] w-16 h-16 text-cyan-500/[0.08] dark:text-cyan-400/[0.12] animate-float-keycap" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" style="animation-delay: -4s;">
        <rect x="6" y="6" width="52" height="52" rx="10" ry="10"/>
        <rect x="12" y="10" width="40" height="40" rx="6" ry="6"/>
        <text x="32" y="38" text-anchor="middle" fill="currentColor" font-size="18" font-weight="bold" font-family="monospace">T</text>
    </svg>
    <!-- A — derecha medio -->
    <svg class="absolute right-[15%] top-[55%] w-20 h-20 text-indigo-500/[0.08] dark:text-indigo-400/[0.12] animate-float-keycap-reverse" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" style="animation-delay: -1.5s;">
        <rect x="6" y="6" width="52" height="52" rx="10" ry="10"/>
        <rect x="12" y="10" width="40" height="40" rx="6" ry="6"/>
        <text x="32" y="38" text-anchor="middle" fill="currentColor" font-size="18" font-weight="bold" font-family="monospace">A</text>
    </svg>
    <!-- R — izquierda abajo -->
    <svg class="absolute left-[8%] bottom-[15%] w-28 h-28 text-fuchsia-500/[0.08] dark:text-fuchsia-400/[0.12] animate-float-keycap" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" style="animation-delay: -3.5s;">
        <rect x="6" y="6" width="52" height="52" rx="10" ry="10"/>
        <rect x="12" y="10" width="40" height="40" rx="6" ry="6"/>
        <text x="32" y="38" text-anchor="middle" fill="currentColor" font-size="18" font-weight="bold" font-family="monospace">R</text>
    </svg>
    <!-- E — centro derecha abajo -->
    <svg class="absolute right-[25%] bottom-[10%] w-16 h-16 text-cyan-500/[0.08] dark:text-cyan-400/[0.12] animate-float-keycap-reverse" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" style="animation-delay: -0.5s;">
        <rect x="6" y="6" width="52" height="52" rx="10" ry="10"/>
        <rect x="12" y="10" width="40" height="40" rx="6" ry="6"/>
        <text x="32" y="38" text-anchor="middle" fill="currentColor" font-size="18" font-weight="bold" font-family="monospace">E</text>
    </svg>
    <!-- S — derecha abajo -->
    <svg class="absolute right-[5%] bottom-[25%] w-20 h-20 text-indigo-500/[0.08] dark:text-indigo-400/[0.12] animate-float-keycap" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" style="animation-delay: -5s;">
        <rect x="6" y="6" width="52" height="52" rx="10" ry="10"/>
        <rect x="12" y="10" width="40" height="40" rx="6" ry="6"/>
        <text x="32" y="42" font-family="monospace" font-size="18" font-weight="bold" text-anchor="middle" fill="currentColor">S</text>
    </svg>
</div>

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 min-h-screen flex flex-col justify-center relative z-10 pt-20">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        
        <div class="lg:col-span-8 scroll-reveal relative z-10 group">
            <div class="flex items-center gap-4 mb-6">
                <span class="h-px w-16 bg-gradient-to-r from-fuchsia-600 to-cyan-500 animate-width-pulse"></span>
                <span class="text-xs font-black uppercase tracking-[0.4em] bg-clip-text text-transparent bg-gradient-to-r from-fuchsia-600 to-cyan-500">Engineering & Design</span>
            </div>
            
            <h1 id="interactive-title" class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl xl:text-9xl font-black tracking-tighter text-gray-900 dark:text-white leading-[0.9] uppercase break-keep relative">
                <span class="absolute -inset-8 bg-gradient-to-r from-fuchsia-500/20 via-indigo-500/10 to-cyan-500/20 blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-1000 -z-10 pointer-events-none"></span>
                Periféricos <br/> 
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-fuchsia-500 via-indigo-500 to-cyan-500 dark:from-fuchsia-400 dark:via-indigo-400 dark:to-cyan-400 animate-gradient-x italic filter drop-shadow-[0_0_25px_rgba(168,85,247,0.4)]">Custom.</span>
            </h1>
        </div>

        <div class="lg:col-span-4 border-l-2 border-indigo-600/30 pl-8 py-4 scroll-reveal delay-200">
            <div class="flex items-center gap-2 mb-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-indigo-500 dark:text-cyan-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                <p class="text-[10px] font-black uppercase tracking-[0.3em] text-indigo-500 dark:text-cyan-400">Maker & Developer</p>
            </div>
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-1 flex items-center gap-3">Antares Cabrera. <span class="inline-flex items-center gap-1.5 text-[9px] font-bold uppercase tracking-widest text-green-600 dark:text-green-400 bg-green-50 dark:bg-green-500/10 px-2.5 py-1 rounded-full border border-green-200/50 dark:border-green-500/20"><span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>Activo</span></h2>
            <p class="text-gray-600 dark:text-gray-300 font-light leading-relaxed mb-6">
                Estudiante de Ingeniería en Informática, apasionado por el hardware y el código. <br/>
                Cada pieza es <span class="italic font-medium text-gray-900 dark:text-white relative"><span class="relative z-10">desarrollada y ensamblada a mano</span><span class="absolute bottom-0 left-0 w-full h-2 bg-fuchsia-500/30 -z-10 rounded-sm"></span></span> por mí para garantizar la máxima calidad.
            </p>
        </div>
    </div>

    <!-- Scroll down indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 opacity-30 animate-pulse">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-gray-400 dark:text-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
    </div>

    <div id="reveal-text" class="mt-32 max-w-4xl opacity-0 translate-y-10 transition-all duration-1000 ease-out border-y border-gray-200 dark:border-gray-800 py-12">
        <blockquote class="text-xl md:text-3xl font-light text-gray-500 dark:text-gray-400 leading-tight">
            "Todo lo que ves acá nace de la curiosidad y necesidad. No solo diseño estos periféricos, sino que <span class="text-gray-900 dark:text-white font-medium italic">son los mismos que uso en mi día a día</span> para trabajar, estudiar y jugar."
        </blockquote>
    </div>
</section>

<script>
    // --- Interactive Title Letters with Scroll Wave ---
    const title = document.getElementById('interactive-title');
    if (title) {
        const text = title.innerText;
        title.innerHTML = '';
        const letterSpans = [];
        let i = 0;
        [...text].forEach(char => {
            if (char === '\n') {
                title.appendChild(document.createElement('br'));
            } else {
                const span = document.createElement('span');
                span.innerText = char === ' ' ? '\u00A0' : char;
                span.className = 'inline-block cursor-default transition-colors duration-200 hover:text-cyan-500 dark:hover:text-fuchsia-400';
                span.style.transition = 'transform 0.1s linear, opacity 0.1s linear, color 0.2s';
                span.dataset.index = i;
                title.appendChild(span);
                letterSpans.push(span);
                i++;
            }
        });

        // Scroll-based wave dissolution
        const totalLetters = letterSpans.length;
        let ticking = false;
        window.addEventListener('scroll', () => {
            if (!ticking) {
                requestAnimationFrame(() => {
                    const scrollY = window.scrollY;
                    const triggerStart = 80;
                    const triggerEnd = 500;
                    const progress = Math.max(0, Math.min(1, (scrollY - triggerStart) / (triggerEnd - triggerStart)));
                    
                    letterSpans.forEach((span, idx) => {
                        // Wave offset: letters further right dissolve slightly later
                        const wave = idx / totalLetters;
                        const p = Math.max(0, Math.min(1, (progress - wave * 0.3) / 0.7));
                        const eased = p * p; // ease-in for dramatic feel
                        
                        const moveY = eased * -(30 + wave * 60);
                        const moveX = eased * (idx % 2 === 0 ? -1 : 1) * (10 + wave * 20);
                        const opacity = 1 - eased;
                        
                        span.style.transform = `translate(${moveX}px, ${moveY}px)`;
                        span.style.opacity = opacity;
                    });
                    ticking = false;
                });
                ticking = true;
            }
        }, { passive: true });
    }

    // --- Floating Particles Canvas ---
    const canvas = document.getElementById('particles-canvas');
    if (canvas) {
        const ctx = canvas.getContext('2d');
        let particles = [];
        const PARTICLE_COUNT = 40;

        function resizeCanvas() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }
        resizeCanvas();
        window.addEventListener('resize', resizeCanvas, { passive: true });

        function createParticle() {
            const isDark = document.documentElement.classList.contains('dark');
            const colors = isDark
                ? ['rgba(168,85,247,', 'rgba(6,182,212,', 'rgba(99,102,241,']
                : ['rgba(99,102,241,', 'rgba(168,85,247,', 'rgba(6,182,212,'];
            const color = colors[Math.floor(Math.random() * colors.length)];
            return {
                x: Math.random() * canvas.width,
                y: Math.random() * canvas.height,
                radius: Math.random() * 2 + 0.5,
                speedX: (Math.random() - 0.5) * 0.3,
                speedY: (Math.random() - 0.5) * 0.3,
                opacity: Math.random() * 0.5 + 0.1,
                color: color
            };
        }

        for (let i = 0; i < PARTICLE_COUNT; i++) particles.push(createParticle());

        function drawParticles() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            particles.forEach(p => {
                p.x += p.speedX;
                p.y += p.speedY;
                if (p.x < 0) p.x = canvas.width;
                if (p.x > canvas.width) p.x = 0;
                if (p.y < 0) p.y = canvas.height;
                if (p.y > canvas.height) p.y = 0;
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
                ctx.fillStyle = p.color + p.opacity + ')';
                ctx.fill();
            });

            // Draw connections between nearby particles
            for (let i = 0; i < particles.length; i++) {
                for (let j = i + 1; j < particles.length; j++) {
                    const dx = particles[i].x - particles[j].x;
                    const dy = particles[i].y - particles[j].y;
                    const dist = Math.sqrt(dx * dx + dy * dy);
                    if (dist < 150) {
                        ctx.beginPath();
                        ctx.moveTo(particles[i].x, particles[i].y);
                        ctx.lineTo(particles[j].x, particles[j].y);
                        const lineOpacity = (1 - dist / 150) * 0.15;
                        ctx.strokeStyle = particles[i].color + lineOpacity + ')';
                        ctx.lineWidth = 0.5;
                        ctx.stroke();
                    }
                }
            }
            requestAnimationFrame(drawParticles);
        }
        drawParticles();
    }

    // --- Mouse Parallax Effect ---
    document.addEventListener('mousemove', (e) => {
        // Obtenemos coordenadas normalizadas del mouse de -1 a 1
        const x = (e.clientX / window.innerWidth - 0.5) * 2;
        const y = (e.clientY / window.innerHeight - 0.5) * 2;

        const layer1 = document.getElementById('parallax-layer-1'); // Particles (closest)
        const layer2 = document.getElementById('parallax-layer-2'); // Grid (middle)
        const layer3 = document.getElementById('parallax-layer-3'); // Orbs (furthest)

        // Multiplicadores al triple para que el efecto sea muy notorio
        if (layer1) layer1.style.transform = `translate(${x * -60}px, ${y * -60}px)`; 
        if (layer2) layer2.style.transform = `translate(${x * -30}px, ${y * -30}px)`; 
        if (layer3) layer3.style.transform = `translate(${x * -90}px, ${y * -90}px)`; 
    });
</script>
