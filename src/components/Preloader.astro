---
<div id="fast-preloader" class="fixed inset-0 z-[100] bg-[#030014] flex flex-col justify-center items-center pointer-events-none transition-opacity duration-700 ease-out">
    <div class="relative flex items-center justify-center">
        <!-- Logo Text -->
        <h1 class="text-4xl md:text-5xl font-black text-white tracking-tighter uppercase relative z-10 animate-pulse">
            Antares<span class="text-transparent bg-clip-text bg-gradient-to-r from-fuchsia-500 to-cyan-500">.</span>
        </h1>
        
        <!-- Glows -->
        <div class="absolute w-32 h-32 bg-fuchsia-500/20 blur-[40px] rounded-full"></div>
        <div class="absolute w-32 h-32 bg-cyan-500/20 blur-[40px] rounded-full translate-x-10"></div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const preloader = document.getElementById('fast-preloader');
        if (!preloader) return;

        // If user has already seen it this session, fade out instantly
        if (sessionStorage.getItem('antares_fast_boot')) {
            preloader.style.opacity = '0';
            setTimeout(() => { preloader.style.display = 'none'; }, 50);
            return;
        }

        // Show a super fast glowing logo, then fade out seamlessly (total time ~0.6s)
        setTimeout(() => {
            preloader.style.opacity = '0';
            sessionStorage.setItem('antares_fast_boot', 'true');
            
            setTimeout(() => {
                preloader.style.display = 'none';
            }, 700); // Wait for transition duration
        }, 300); // Super short delay, barely noticeable
    });
</script>
