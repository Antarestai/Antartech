<style>
    .marquee-track {
        display: flex;
        width: max-content;
        animation: marquee 60s linear infinite;
    }
    
    .marquee-track:hover {
        animation-play-state: paused;
    }
    
    @keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(calc(-50% - 1.5rem)); }
    }
</style>
