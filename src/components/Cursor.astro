---
// src/components/Cursor.astro
---
<div id="custom-cursor" class="fixed pointer-events-none z-[100] hidden md:flex items-center justify-center mix-blend-difference transition-transform duration-[50ms] ease-out">
    <div class="relative flex items-center justify-center">
        <!-- Retícula exterior suavizada (aura) -->
        <div class="cursor-ring absolute w-6 h-6 border border-white/30 rounded-full transition-all duration-300"></div>
        <!-- Puntos direccionales -->
        <div class="cursor-crosshair absolute w-10 h-10 transition-all duration-300 opacity-0 scale-50">
            <span class="absolute top-0 left-1/2 -translate-x-1/2 w-px h-1.5 bg-white/50"></span>
            <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-px h-1.5 bg-white/50"></span>
            <span class="absolute left-0 top-1/2 -translate-y-1/2 w-1.5 h-px bg-white/50"></span>
            <span class="absolute right-0 top-1/2 -translate-y-1/2 w-1.5 h-px bg-white/50"></span>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        // Solo instanciar puntero si es un dispositivo con 'hover' disponible
        if (!window.matchMedia("(hover: hover)").matches) return;

        const cursor = document.getElementById('custom-cursor');
        if (!cursor) return;

        const ring = cursor.querySelector('.cursor-ring') as HTMLElement;
        const crosshair = cursor.querySelector('.cursor-crosshair') as HTMLElement;
        
        // Desactivamos el ocultamiento del cursor nativo para mantener la sensibilidad/precisión real
        // document.body.style.cursor = 'none';

        let mouseX = window.innerWidth / 2;
        let mouseY = window.innerHeight / 2;

        let cursorX = mouseX;
        let cursorY = mouseY;

        // Suavizado del movimiento (más rápido para menor latencia percibida)
        const speed = 0.35;

        function animate() {
            cursorX += (mouseX - cursorX) * speed;
            cursorY += (mouseY - cursorY) * speed;
            
            cursor.style.transform = `translate(${cursorX}px, ${cursorY}px) translate(-50%, -50%)`;
            requestAnimationFrame(animate);
        }

        window.addEventListener('mousemove', (e) => {
            mouseX = e.clientX;
            mouseY = e.clientY;
            
            // Si estaba oculto por salirse, lo mostramos
            if (cursor.style.opacity === '0') {
                cursor.style.opacity = '1';
            }
        });

        // Ocultar si sale del documento
        document.addEventListener('mouseleave', () => cursor.style.opacity = '0');
        document.addEventListener('mouseenter', () => cursor.style.opacity = '1');

        // Efectos al hacer hover sobre elementos interactivos
        const interactables = document.querySelectorAll('a, button, input, textarea, summary, details, [role="button"]');
        
        interactables.forEach(el => {
            el.addEventListener('mouseenter', () => {
                // Ocultar el aro, expandir cruz
                if(ring) { ring.style.transform = 'scale(1.5)'; ring.style.opacity = '0'; }
                if(crosshair) { crosshair.style.opacity = '1'; crosshair.style.transform = 'scale(1)'; }
            });
            
            el.addEventListener('mouseleave', () => {
                // Volver al estado default
                if(ring) { ring.style.transform = 'scale(1)'; ring.style.opacity = '1'; }
                if(crosshair) { crosshair.style.opacity = '0'; crosshair.style.transform = 'scale(0.5)'; }
            });
        });

        requestAnimationFrame(animate);
    });
</script>
