---
// src/components/Contact.astro
const waLink = "https://wa.me/5491122631776";
const igLink = "https://instagram.com/antares.tech";
const discordLink = "https://discord.gg/antarestai";
---
<section id="contact" class="py-24 bg-gray-100 dark:bg-[#02000d] relative z-20 transition-colors duration-700 overflow-hidden">
    <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-cyan-500/30 to-transparent"></div>
    <div class="absolute right-0 bottom-0 w-[500px] h-[500px] rounded-full bg-cyan-500/5 dark:bg-cyan-600/10 blur-[120px] pointer-events-none"></div>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="flex items-center mb-16 px-4 scroll-reveal">
            <h2 class="text-3xl font-black text-gray-900 dark:text-white mr-8 uppercase tracking-tighter">Contacto</h2>
            <div class="h-px bg-gradient-to-r from-cyan-500/30 to-transparent flex-grow"></div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 px-4">
            <div class="space-y-12 scroll-reveal">
                <h3 class="text-5xl lg:text-6xl font-black text-gray-900 dark:text-white uppercase leading-[0.9] tracking-tighter">Llevá tu setup <br/> al próximo nivel.</h3>
                <p class="text-xl text-gray-600 dark:text-gray-300 font-light leading-relaxed">
                    Si buscás un dispositivo custom para tu setup o necesitás soporte técnico con tu compra, escribime. Atiendo pedidos por mayor y consultas.
                </p>
                <div class="flex gap-4">
                    <a href={waLink} target="_blank" aria-label="WhatsApp" class="flex items-center justify-center w-14 h-14 bg-white/80 dark:bg-white/5 backdrop-blur-md border border-gray-200 dark:border-white/10 rounded-2xl hover:border-green-500 hover:bg-green-50 dark:hover:bg-green-500/10 hover:text-green-500 text-gray-500 dark:text-gray-400 transition-all duration-500 hover:-translate-y-1 group/wa hover:shadow-lg hover:shadow-green-500/20"><svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 group-hover/wa:scale-110 transition-transform duration-500" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9" /><path d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1" /></svg></a>
                    <a href={igLink} target="_blank" aria-label="Instagram" class="flex items-center justify-center w-14 h-14 bg-white/80 dark:bg-white/5 backdrop-blur-md border border-gray-200 dark:border-white/10 rounded-2xl hover:border-fuchsia-500 hover:bg-fuchsia-50 dark:hover:bg-fuchsia-500/10 hover:text-fuchsia-500 text-gray-500 dark:text-gray-400 transition-all duration-500 hover:-translate-y-1 group/ig hover:shadow-lg hover:shadow-fuchsia-500/20"><svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 group-hover/ig:scale-110 transition-transform duration-500" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4m0 4a4 4 0 0 1 4 -4h8a4 4 0 0 1 4 4v8a4 4 0 0 1 -4 4h-8a4 4 0 0 1 -4 -4z" /><path d="M12 12m-3 0a3 3 0 1 0 6 0a3 3 0 1 0 -6 0" /><path d="M16.5 7.5l0 .01" /></svg></a>
                    <a href={discordLink} target="_blank" aria-label="Discord" class="flex items-center justify-center w-14 h-14 bg-white/80 dark:bg-white/5 backdrop-blur-md border border-gray-200 dark:border-white/10 rounded-2xl hover:border-indigo-500 hover:bg-indigo-50 dark:hover:bg-indigo-500/10 hover:text-indigo-500 text-gray-500 dark:text-gray-400 transition-all duration-500 hover:-translate-y-1 group/dc hover:shadow-lg hover:shadow-indigo-500/20"><svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 group-hover/dc:scale-110 transition-transform duration-500" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M8 12a1 1 0 1 0 2 0a1 1 0 0 0 -2 0" /><path d="M14 12a1 1 0 1 0 2 0a1 1 0 0 0 -2 0" /><path d="M15.5 17c0 1 1.5 3 2 3c1.5 0 2.833 -1.667 3.5 -3c.667 -1.667 .5 -5.833 -1.5 -11.5c-1.457 -1.015 -3 -1.5 -4.5 -1.5l-1 2.5l-2 0l-1 -2.5c-1.5 0 -3.043 .485 -4.5 1.5c-2 5.667 -2.167 9.833 -1.5 11.5c.667 1.333 2 3 3.5 3c.5 0 2 -2 2 -3" /></svg></a>
                </div>
            </div>

            <!-- Terminal-style Glass Form -->
            <div class="scroll-reveal rounded-2xl overflow-hidden bg-white/70 dark:bg-white/[0.04] backdrop-blur-3xl border border-white/60 dark:border-white/[0.08] shadow-2xl shadow-indigo-500/10 dark:shadow-indigo-950/50 ring-1 ring-white/30 dark:ring-white/[0.05] relative group/form" style="transition-delay: 200ms">
                <!-- Glass glow on hover -->
                <div class="absolute inset-0 bg-gradient-to-br from-cyan-500/10 via-transparent to-indigo-500/10 dark:from-cyan-500/15 dark:to-indigo-500/15 opacity-0 group-hover/form:opacity-100 transition-opacity duration-1000 pointer-events-none rounded-2xl"></div>
                <!-- Terminal header -->
                <div class="flex items-center gap-2 px-5 py-3 bg-white/50 dark:bg-white/[0.03] border-b border-gray-200/50 dark:border-white/5 relative z-10">
                    <span class="w-3 h-3 rounded-full bg-red-400"></span>
                    <span class="w-3 h-3 rounded-full bg-yellow-400"></span>
                    <span class="w-3 h-3 rounded-full bg-green-400"></span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-gray-300 dark:text-gray-600 ml-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
                    <span class="font-['Fira_Code'] text-[11px] text-gray-400 dark:text-gray-500">contacto</span>
                </div>
                <!-- Form body -->
                <div class="p-6 md:p-10 relative z-10">
                    <p class="font-['Fira_Code'] text-[11px] text-gray-300 dark:text-gray-600 mb-6 flex items-center gap-1.5"><span class="text-cyan-400 dark:text-cyan-500">›</span> Completá el formulario y te respondemos a la brevedad <span class="w-1.5 h-4 bg-cyan-400/60 dark:bg-cyan-500/40 animate-pulse inline-block"></span></p>
                    <form action="https://formspree.io/f/xwvrbzob" method="POST" class="space-y-6">
                        <div>
                            <label for="name" class="block text-[10px] font-black uppercase tracking-widest text-indigo-500 dark:text-cyan-400 mb-2">Tu Nombre</label>
                            <input id="name" type="text" name="name" required class="w-full bg-white/80 dark:bg-black/30 backdrop-blur-sm border border-gray-200/80 dark:border-white/10 rounded-xl p-4 text-sm text-gray-900 dark:text-white outline-none focus:border-cyan-500 dark:focus:border-cyan-400 focus:ring-2 focus:ring-cyan-500/30 placeholder-gray-400 dark:placeholder-gray-600 transition-all duration-300" placeholder="Tu nombre..." />
                        </div>
                        <div>
                            <label for="email" class="block text-[10px] font-black uppercase tracking-widest text-indigo-500 dark:text-cyan-400 mb-2">Email</label>
                            <input id="email" type="email" name="email" required class="w-full bg-white/80 dark:bg-black/30 backdrop-blur-sm border border-gray-200/80 dark:border-white/10 rounded-xl p-4 text-sm text-gray-900 dark:text-white outline-none focus:border-cyan-500 dark:focus:border-cyan-400 focus:ring-2 focus:ring-cyan-500/30 placeholder-gray-400 dark:placeholder-gray-600 transition-all duration-300" placeholder="tu@email.com" />
                        </div>
                        <div>
                            <label for="message" class="block text-[10px] font-black uppercase tracking-widest text-indigo-500 dark:text-cyan-400 mb-2">Consulta</label>
                            <textarea id="message" name="message" rows="4" required class="w-full bg-white/80 dark:bg-black/30 backdrop-blur-sm border border-gray-200/80 dark:border-white/10 rounded-xl p-4 text-sm text-gray-900 dark:text-white outline-none focus:border-cyan-500 dark:focus:border-cyan-400 focus:ring-2 focus:ring-cyan-500/30 resize-none placeholder-gray-400 dark:placeholder-gray-600 transition-all duration-300" placeholder="¿En qué puedo ayudarte?"></textarea>
                        </div>
                        <button type="submit" class="w-full bg-gradient-to-r from-indigo-600 to-cyan-500 hover:from-indigo-500 hover:to-cyan-400 text-white font-black uppercase py-5 rounded-xl text-xs tracking-[0.2em] transition-all duration-500 shadow-xl shadow-cyan-500/25 hover:shadow-cyan-500/40 hover:-translate-y-1">
                            Enviar Consulta
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
