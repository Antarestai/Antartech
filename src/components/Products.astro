---
// src/components/Products.astro
import { Image } from 'astro:assets';

const { featuredDevices } = Astro.props;

const formatter = new Intl.NumberFormat('es-AR', {
    style: 'currency',
    currency: 'ARS',
    maximumFractionDigits: 0
});
---

<section id="store" class="py-24 bg-white/50 dark:bg-[#030014]/50 backdrop-blur-3xl transition-colors duration-700 relative z-20 overflow-hidden">
    <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-indigo-500/50 to-transparent"></div>
    <div class="absolute -left-40 top-40 w-80 h-80 rounded-full bg-indigo-500/10 dark:bg-indigo-600/10 blur-[100px] pointer-events-none animate-float-slow"></div>
    <div class="absolute right-0 bottom-20 w-64 h-64 rounded-full bg-fuchsia-500/5 dark:bg-fuchsia-600/10 blur-[100px] pointer-events-none animate-float-slow-reverse"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center mb-16 px-4 scroll-reveal">
            <h2 class="text-3xl font-black text-gray-900 dark:text-white mr-8 uppercase tracking-tighter">Productos / Proyectos</h2>
            <div class="h-px bg-gradient-to-r from-indigo-500/50 to-transparent flex-grow"></div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 px-4">
            {featuredDevices.map((device: any, index: number) => (
                <div class={`card-glow group relative bg-white/90 dark:bg-white/[0.06] backdrop-blur-3xl border border-white/60 dark:border-white/[0.08] rounded-[2.5rem] overflow-hidden shadow-xl shadow-indigo-500/5 dark:shadow-2xl dark:shadow-indigo-950/50 transition-all duration-700 hover:-translate-y-4 hover:shadow-2xl hover:shadow-indigo-500/25 hover:border-indigo-400/60 dark:hover:border-indigo-400/30 ring-1 ring-white/20 dark:ring-white/[0.05] flex flex-col will-change-transform scroll-reveal`} style={`transition-delay: ${index * 75}ms`}>
                    <div class="absolute inset-0 -translate-x-full group-hover:translate-x-full bg-gradient-to-r from-transparent via-white/40 dark:via-white/10 to-transparent transition-transform duration-[1.5s] ease-in-out pointer-events-none z-20"></div>

                    <div class="h-80 overflow-hidden relative z-10 bg-gray-100 dark:bg-gray-900/50">
                        {device.data.image ? (
                            <Image src={device.data.image as any} alt={device.data.title} width={800} height={600} format="webp" class="w-full h-full object-cover transform transition-transform duration-1000 group-hover:scale-110 will-change-transform" />
                        ) : (
                            <div class="w-full h-full flex items-center justify-center text-7xl bg-gray-200 dark:bg-gray-800">🛠️</div>
                        )}
                        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
                        
                        {/* Stock Badge */}
                        {device.data.stock && (
                            <div class="absolute top-4 right-4 z-30">
                                <span class={`
                                    px-3 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest shadow-lg backdrop-blur-md border outline outline-1 outline-white/10
                                    ${device.data.stock === 'En Stock' ? 'bg-green-500/20 text-green-700 dark:text-green-400 border-green-500/30' : ''}
                                    ${device.data.stock === 'A Pedido' ? 'bg-yellow-500/20 text-yellow-700 dark:text-yellow-400 border-yellow-500/30' : ''}
                                    ${device.data.stock === 'Sold Out' ? 'bg-red-500/20 text-red-700 dark:text-red-400 border-red-500/30' : ''}
                                    ${device.data.stock === 'Próximamente' ? 'bg-purple-500/20 text-purple-700 dark:text-purple-400 border-purple-500/30' : ''}
                                `}>
                                    <span class={`inline-block w-1.5 h-1.5 rounded-full mr-1 
                                        ${device.data.stock === 'En Stock' ? 'bg-green-500 animate-pulse' : ''}
                                        ${device.data.stock === 'A Pedido' ? 'bg-yellow-500' : ''}
                                        ${device.data.stock === 'Sold Out' ? 'bg-red-500' : ''}
                                        ${device.data.stock === 'Próximamente' ? 'bg-purple-500 animate-pulse' : ''}
                                    `}></span>
                                    {device.data.stock}
                                </span>
                            </div>
                        )}
                    </div>

                    <div class="p-10 flex flex-col flex-grow relative z-10">
                        <div class="flex flex-wrap gap-2 mb-4">
                            {device.data.tags && device.data.tags.map((tag: string) => (
                                <span class="text-[9px] font-black uppercase tracking-widest text-indigo-600 dark:text-cyan-400 bg-indigo-100/80 dark:bg-cyan-900/40 px-3 py-1.5 rounded-md border border-indigo-200 dark:border-cyan-800/50 backdrop-blur-md shadow-sm">{tag}</span>
                            ))}
                        </div>
                        <h3 class="text-3xl font-black text-gray-900 dark:text-white mb-3 uppercase tracking-tighter leading-tight font-sans text-ellipsis overflow-hidden group-hover:text-indigo-600 dark:group-hover:text-cyan-400 transition-colors duration-500">{device.data.title}</h3>
                        <p class="text-gray-600 dark:text-gray-400 text-base mb-10 leading-relaxed font-light line-clamp-3">{device.data.description}</p>
                        
                        <div class="mt-auto flex items-center gap-4">
                            {device.data.stock === 'Próximamente' ? (
                                <div class="flex-grow flex justify-center items-center bg-gray-200/50 dark:bg-white/[0.05] text-gray-500 dark:text-gray-600 py-4.5 rounded-2xl font-black uppercase text-xs tracking-[0.1em] border border-gray-300/50 dark:border-white/5 cursor-not-allowed">
                                    En Desarrollo
                                </div>
                            ) : (
                                <>
                                    <a href={`/devices/${device.id}`} class="flex-grow flex justify-center items-center bg-gray-900 dark:bg-white text-white dark:text-gray-900 py-4.5 rounded-2xl font-black uppercase text-xs tracking-[0.1em] transition-all duration-500 hover:bg-gradient-to-r hover:from-fuchsia-600 hover:to-indigo-600 dark:hover:from-fuchsia-500 dark:hover:to-cyan-500 dark:hover:text-white shadow-lg hover:shadow-indigo-500/30">Setup & Config</a>
                                    <!-- Botón Añadir al Carrito -->
                                    <button 
                                        class="add-to-cart-btn flex items-center justify-center w-14 h-14 bg-indigo-50 dark:bg-indigo-500/10 border border-indigo-200 dark:border-indigo-500/30 rounded-2xl hover:bg-indigo-600 hover:border-indigo-600 dark:hover:bg-cyan-500 dark:hover:border-cyan-500 text-indigo-600 hover:text-white transition-all duration-500 shrink-0 hover:shadow-lg hover:shadow-indigo-500/30 dark:hover:shadow-cyan-500/30 group/cart"
                                        data-id={device.id}
                                        data-title={device.data.title}
                                        data-price={device.data.price || 45000} 
                                        data-image={device.data.image ? typeof device.data.image === 'object' ? device.data.image.src : device.data.image : ''}
                                        aria-label={`Añadir ${device.data.title} al carrito`}
                                    >
                                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" class="group-hover/cart:scale-110 transition-transform duration-500" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
                                            <path d="M3 6h18"/>
                                            <path d="M12 10v6"/>
                                            <path d="M9 13h6"/>
                                        </svg>
                                    </button>
                                </>
                            )}
                        </div>
                    </div>
                </div>
            ))}

            {/* Tarjeta de Próximamente / General Teaser */}
            <div class={`card-glow group relative bg-gradient-to-br from-indigo-500/5 to-fuchsia-500/5 dark:from-indigo-500/10 dark:to-fuchsia-500/10 backdrop-blur-3xl border-2 border-dashed border-indigo-200 dark:border-white/10 rounded-[2.5rem] overflow-hidden transition-all duration-700 hover:-translate-y-4 hover:border-indigo-400/50 flex flex-col will-change-transform scroll-reveal`} style={`transition-delay: ${featuredDevices.length * 75}ms`}>
                <div class="h-80 flex items-center justify-center bg-gray-50/50 dark:bg-white/[0.02] relative overflow-hidden group">
                    <div class="absolute inset-0 bg-gradient-to-br from-indigo-500/10 via-transparent to-fuchsia-500/10 opacity-0 group-hover:opacity-100 transition-opacity duration-1000"></div>
                    <div class="relative z-10 text-center space-y-4">
                        <div class="w-20 h-20 mx-auto rounded-3xl bg-white dark:bg-white/10 shadow-xl shadow-indigo-500/10 flex items-center justify-center transform group-hover:rotate-12 transition-transform duration-500">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-indigo-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 3v18M3 12h18"/>
                            </svg>
                        </div>
                        <p class="text-xs font-black uppercase tracking-[0.2em] text-indigo-500 dark:text-indigo-400">Próximamente</p>
                    </div>
                </div>
                <div class="p-10 flex flex-col flex-grow text-center">
                    <h3 class="text-3xl font-black text-gray-900 dark:text-white mb-3 uppercase tracking-tighter leading-tight font-sans">Nuevos Proyectos</h3>
                    <p class="text-gray-600 dark:text-gray-400 text-base mb-10 leading-relaxed font-light">Estamos diseñando el futuro de tu setup. Nuevos periféricos custom están en camino.</p>
                    <div class="mt-auto">
                        <a href="/#contact" class="inline-flex items-center gap-2 text-xs font-black uppercase tracking-widest text-indigo-600 dark:text-cyan-400 group/link">
                            Sugerir una idea
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transform group-hover/link:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    import { cartStore } from '../scripts/cartStore.js';

    document.addEventListener('DOMContentLoaded', () => {
        // Lógica para Añadir al Carrito
        const addButtons = document.querySelectorAll('.add-to-cart-btn');
        
        addButtons.forEach(btn => {
            btn.addEventListener('click', (e) => {
                const button = e.currentTarget as HTMLElement;
                const id = button.dataset.id;
                const title = button.dataset.title;
                const price = parseFloat(button.dataset.price || '0');
                const image = button.dataset.image;

                if (id && title) {
                    // Animación de feedback local en el botón
                    const originalHTML = button.innerHTML;
                    button.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="animate-bounce"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
                    button.classList.add('bg-green-500', 'text-white', 'border-green-500');
                    button.classList.remove('text-indigo-600');
                    
                    setTimeout(() => {
                        button.innerHTML = originalHTML;
                        button.classList.remove('bg-green-500', 'text-white', 'border-green-500');
                        button.classList.add('text-indigo-600');
                    }, 1000);

                    // Guardar en store
                    cartStore.addItem({ id, title, price, image });
                    
                    // Abrir Drawer para darle feedback visual al usuario de que entró al carrito
                    window.dispatchEvent(new CustomEvent('antares_open_cart'));
                }
            });
        });
    });
</script>
